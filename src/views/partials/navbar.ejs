<%
// activePage: 'home' | 'products' | 'categories' | 'cart' | ''
const activePage = locals.activePage || '';
const navLinkClass = (page) => activePage === page
  ? 'text-primary font-bold border-b-2 border-primary pb-1 font-body-md text-body-md'
  : 'text-on-surface-variant hover:text-primary transition-transform duration-200 hover:scale-105 font-body-md text-body-md';
const mobileNavLinkClass = (page) => activePage === page
  ? 'flex items-center gap-sm px-md py-sm rounded-xl text-primary font-bold bg-primary-container/15 font-body-md text-body-md'
  : 'flex items-center gap-sm px-md py-sm rounded-xl text-on-surface-variant hover:text-primary hover:bg-surface-container transition-colors font-body-md text-body-md';
%>
<!-- TopNavBar -->
<header
  class="fixed top-0 left-0 w-full z-50 bg-surface/80 backdrop-blur-md shadow-sm"
>
  <div
    class="flex justify-between items-center px-lg py-md w-full max-w-container-max mx-auto"
  >
    <a href="/" class="inline-flex items-center gap-3 font-headline-md text-headline-md font-bold text-primary">
      <img src="/images/logo.png" alt="Xám Pet Shop logo" class="w-10 h-10 object-contain" />
      <span>Xám Pet Shop</span>
    </a>
    <nav class="hidden md:flex items-center gap-xl">
      <a
        class="<%= navLinkClass('home') %>"
        href="/"
        >Trang chủ</a
      >
      <a
        class="<%= navLinkClass('products') %>"
        href="/product"
        >Sản phẩm</a
      >
      <a
        class="<%= navLinkClass('categories') %>"
        href="/homepage/categories"
        >Danh mục</a
      >
    </nav>
    <div class="flex items-center gap-md">
      <a
        href="/cart"
        class="relative inline-flex items-center justify-center text-primary p-2 transition-transform duration-200 hover:scale-110 active:scale-95"
        data-icon="shopping_cart"
      >
        <span class="material-symbols-outlined">shopping_cart</span>
        <span
          id="cartBadge"
          class="hidden absolute -top-1 -right-1 min-w-[18px] h-[18px] rounded-full bg-primary text-white text-[10px] font-bold flex items-center justify-center px-1"
        ></span>
      </a>

      <!-- GUEST: hiển thị khi chưa đăng nhập -->
      <div id="guestNav" class="hidden sm:flex items-center gap-sm">
        <a
          href="/auth/login"
          class="text-on-surface-variant hover:text-primary font-label-md px-md py-sm transition-colors"
        >
          Đăng nhập
        </a>
        <a
          href="/auth/register"
          class="bg-primary-container text-on-primary-container px-lg py-sm rounded-full font-label-md hover:scale-105 transition-all active:scale-95 inline-block"
        >
          Đăng ký
        </a>
      </div>

      <!-- USER: hiển thị khi đã đăng nhập -->
      <div id="userNav" class="hidden items-center gap-sm relative">
        <!-- Admin badge (chỉ hiện với admin) -->
        <a
          id="adminLink"
          href="/admin"
          class="hidden items-center gap-xs px-md py-1 bg-primary text-on-primary rounded-full font-label-sm hover:opacity-90 transition-opacity"
        >
          <span class="material-symbols-outlined text-[14px]"
            >admin_panel_settings</span
          >
          Admin
        </a>

        <!-- Avatar + tên -->
        <div class="relative">
          <button id="userAvatarBtn" class="flex items-center gap-sm group">
            <div id="userAvatar">A</div>
            <span
              id="userName"
              class="hidden sm:block font-label-md text-on-surface max-w-[120px] truncate"
            ></span>
            <span
              class="material-symbols-outlined text-on-surface-variant text-[18px] transition-transform group-hover:text-primary"
              id="chevronIcon"
              >expand_more</span
            >
          </button>

          <!-- Dropdown menu -->
          <div
            id="userMenu"
            class="absolute right-0 top-full mt-2 w-52 bg-surface-container-lowest rounded-2xl shadow-lg border border-outline-variant/30 overflow-hidden z-50"
          >
            <div class="px-lg py-md border-b border-outline-variant/20">
              <p
                class="font-label-md text-on-surface truncate"
                id="menuUserName"
              ></p>
              <p
                class="text-label-sm text-on-surface-variant truncate"
                id="menuUserEmail"
              ></p>
            </div>
            <div class="py-sm">
              <a
                href="/profile"
                class="flex items-center gap-sm px-lg py-sm text-on-surface-variant hover:text-primary hover:bg-surface-container transition-colors font-label-md"
              >
                <span class="material-symbols-outlined text-[18px]"
                  >account_circle</span
                >
                Hồ sơ của tôi
              </a>
              <a
                href="/order/detail"
                class="flex items-center gap-sm px-lg py-sm text-on-surface-variant hover:text-primary hover:bg-surface-container transition-colors font-label-md"
              >
                <span class="material-symbols-outlined text-[18px]"
                  >receipt_long</span
                >
                Đơn hàng của tôi
              </a>
              <a
                id="menuAdminLink"
                href="/admin"
                class="hidden items-center gap-sm px-lg py-sm text-on-surface-variant hover:text-primary hover:bg-surface-container transition-colors font-label-md"
              >
                <span class="material-symbols-outlined text-[18px]"
                  >admin_panel_settings</span
                >
                Trang Admin
              </a>
              <button
                id="logoutBtn"
                class="w-full flex items-center gap-sm px-lg py-sm text-error hover:bg-error-container/20 transition-colors font-label-md"
              >
                <span class="material-symbols-outlined text-[18px]"
                  >logout</span
                >
                Đăng xuất
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- Mobile menu toggle -->
      <button
        id="mobileMenuBtn"
        class="md:hidden inline-flex items-center justify-center p-2 text-on-surface-variant hover:text-primary transition-colors"
        aria-label="Mở menu"
        aria-expanded="false"
      >
        <span class="material-symbols-outlined" id="mobileMenuIcon">menu</span>
      </button>
    </div>
  </div>

  <!-- Mobile nav panel -->
  <div
    id="mobileNav"
    class="md:hidden grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-in-out bg-surface/95 backdrop-blur-md"
  >
    <nav class="overflow-hidden flex flex-col px-lg py-sm gap-1">
      <a href="/" class="<%= mobileNavLinkClass('home') %>">
        <span class="material-symbols-outlined text-[20px]">home</span>
        Trang chủ
      </a>
      <a href="/product" class="<%= mobileNavLinkClass('products') %>">
        <span class="material-symbols-outlined text-[20px]">storefront</span>
        Sản phẩm
      </a>
      <a href="/homepage/categories" class="<%= mobileNavLinkClass('categories') %>">
        <span class="material-symbols-outlined text-[20px]">category</span>
        Danh mục
      </a>
      <a href="/cart" class="<%= mobileNavLinkClass('cart') %>">
        <span class="material-symbols-outlined text-[20px]">shopping_cart</span>
        Giỏ hàng
      </a>
      <div id="mobileGuestNav" class="hidden flex-col gap-sm pt-sm mt-sm border-t border-outline-variant/20">
        <a href="/auth/login" class="flex items-center justify-center px-md py-sm rounded-xl text-primary font-label-md border border-primary/30 hover:bg-primary-container/10 transition-colors">Đăng nhập</a>
        <a href="/auth/register" class="flex items-center justify-center px-md py-sm rounded-xl bg-primary-container text-on-primary-container font-label-md hover:scale-[1.02] transition-transform">Đăng ký</a>
      </div>
    </nav>
  </div>
</header>
