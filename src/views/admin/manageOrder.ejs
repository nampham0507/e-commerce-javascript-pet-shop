<!doctype html>

<html class="light" lang="vi">
  <head>
    <%- include('../partials/head-meta') %>
    <title>Quản lý đơn hàng - Xám Pet Shop</title>
    <style>
      .material-symbols-outlined {
        font-variation-settings:
          "FILL" 0,
          "wght" 400,
          "GRAD" 0,
          "opsz" 24;
      }
      ::-webkit-scrollbar {
        width: 6px;
      }
      ::-webkit-scrollbar-track {
        background: transparent;
      }
      ::-webkit-scrollbar-thumb {
        background: #d6c3b0;
        border-radius: 10px;
      }
    </style>
    <script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            colors: {
              "on-secondary-container": "#686554",
              error: "#ba1a1a",
              "tertiary-fixed-dim": "#58d5fe",
              "surface-container-high": "#f3e6da",
              "primary-fixed-dim": "#ffb95a",
              "surface-container-lowest": "#ffffff",
              "on-error": "#ffffff",
              "surface-tint": "#845400",
              secondary: "#625f4e",
              "on-tertiary": "#ffffff",
              "primary-container": "#ffb347",
              "tertiary-container": "#52d0f9",
              outline: "#847463",
              "on-surface-variant": "#524535",
              "on-secondary-fixed": "#1e1c0f",
              "on-primary-container": "#704700",
              "surface-dim": "#e5d8cc",
              "inverse-surface": "#372f27",
              "on-tertiary-fixed-variant": "#004d61",
              "on-background": "#211a13",
              "on-primary": "#ffffff",
              "surface-bright": "#fff8f4",
              "inverse-primary": "#ffb95a",
              "outline-variant": "#d6c3b0",
              "secondary-container": "#e8e3cd",
              "on-primary-fixed-variant": "#643f00",
              tertiary: "#006780",
              "error-container": "#ffdad6",
              "surface-variant": "#eee0d4",
              "secondary-fixed": "#e8e3cd",
              "on-error-container": "#93000a",
              primary: "#845400",
              "on-surface": "#211a13",
              "on-primary-fixed": "#2a1800",
              "primary-fixed": "#ffddb6",
              surface: "#fff8f4",
              "tertiary-fixed": "#b8eaff",
              "surface-container-low": "#fff1e5",
              background: "#fff8f4",
              "inverse-on-surface": "#fceee2",
              "surface-container-highest": "#eee0d4",
              "secondary-fixed-dim": "#ccc7b2",
              "on-tertiary-container": "#00576d",
              "on-secondary": "#ffffff",
              "on-secondary-fixed-variant": "#4a4737",
              "on-tertiary-fixed": "#001f28",
              "surface-container": "#f9ecdf",
            },
            borderRadius: {
              DEFAULT: "0.25rem",
              lg: "0.5rem",
              xl: "0.75rem",
              full: "9999px",
            },
            spacing: {
              lg: "24px",
              xs: "4px",
              xl: "40px",
              "margin-mobile": "16px",
              "container-max": "1200px",
              unit: "4px",
              gutter: "24px",
              sm: "8px",
              md: "16px",
            },
            fontFamily: {
              "label-md": ["Plus Jakarta Sans"],
              "headline-lg": ["Quicksand"],
              "headline-md": ["Quicksand"],
              "body-md": ["Plus Jakarta Sans"],
              "headline-lg-mobile": ["Quicksand"],
              "body-lg": ["Plus Jakarta Sans"],
              "label-sm": ["Plus Jakarta Sans"],
              "headline-xl": ["Quicksand"],
            },
            fontSize: {
              "label-md": [
                "14px",
                {
                  lineHeight: "20px",
                  letterSpacing: "0.01em",
                  fontWeight: "600",
                },
              ],
              "headline-lg": [
                "32px",
                { lineHeight: "40px", fontWeight: "700" },
              ],
              "headline-md": [
                "24px",
                { lineHeight: "32px", fontWeight: "600" },
              ],
              "body-md": ["16px", { lineHeight: "24px", fontWeight: "400" }],
              "headline-lg-mobile": [
                "28px",
                { lineHeight: "36px", fontWeight: "700" },
              ],
              "body-lg": ["18px", { lineHeight: "28px", fontWeight: "400" }],
              "label-sm": ["12px", { lineHeight: "16px", fontWeight: "700" }],
              "headline-xl": [
                "48px",
                {
                  lineHeight: "56px",
                  letterSpacing: "-0.02em",
                  fontWeight: "700",
                },
              ],
            },
          },
        },
      };
    </script>
  </head>
  <body class="bg-surface-bright text-on-surface font-body-md antialiased">
    <%- include('../partials/admin-sidebar', { activePage: 'orders' }) %>
    <!-- Main Content Area -->
    <main class="ml-64 min-h-screen bg-surface p-xl">
      <!-- Header & Stats Row -->
      <header class="mb-xl flex justify-between items-end">
        <div>
          <h2
            class="font-headline-lg text-headline-lg text-on-surface section-heading reveal"
          >
            Quản lý Đơn hàng
          </h2>
        </div>
        <div class="flex gap-md">
          <button
            id="openCreateOrderBtn"
            class="flex items-center gap-xs px-lg py-sm bg-primary text-on-primary rounded-full hover:scale-105 transition-transform shadow-md font-label-md"
          >
            <span class="material-symbols-outlined text-[20px]" data-icon="add"
              >add</span
            >
            Tạo đơn hàng mới
          </button>
        </div>
      </header>
      <!-- Stats Overview (Asymmetric/Bento Style) -->
      <div class="grid grid-cols-12 gap-lg mb-xl">
        <div
          class="col-span-12 md:col-span-4 bg-surface-container-lowest p-lg rounded-xl border border-outline-variant shadow-sm flex flex-col justify-between"
        >
          <div>
            <span
              class="material-symbols-outlined text-primary mb-md"
              data-icon="shopping_cart"
              >shopping_cart</span
            >
            <h3 class="text-on-surface-variant font-label-md">Tổng đơn hàng</h3>
          </div>
          <div class="mt-md">
            <p
              class="text-headline-md font-bold text-on-surface"
              id="statTotalOrders"
            >
              —
            </p>
          </div>
        </div>
        <div
          class="col-span-12 md:col-span-3 bg-surface-container-lowest p-lg rounded-xl border border-outline-variant shadow-sm"
        >
          <span
            class="material-symbols-outlined text-tertiary mb-md"
            data-icon="pending"
            >pending</span
          >
          <h3 class="text-on-surface-variant font-label-md">Đang xử lý</h3>
          <p
            class="text-headline-md font-bold text-on-surface mt-md"
            id="statPendingOrders"
          >
            —
          </p>
        </div>
        <div
          class="col-span-12 md:col-span-5 bg-primary-container p-lg rounded-xl shadow-sm relative overflow-hidden flex items-center"
        >
          <div class="z-10">
            <h3 class="text-on-primary-container font-headline-md font-bold">
              Doanh thu hôm nay
            </h3>
            <p
              class="text-headline-lg font-bold text-on-primary-fixed mt-sm"
              id="statDailyRevenue"
            >
              —
            </p>
          </div>
          <!-- Decorative Graphic -->
          <div class="absolute -right-8 -bottom-8 opacity-20">
            <span
              class="material-symbols-outlined text-[120px]"
              data-icon="pets"
              >pets</span
            >
          </div>
        </div>
      </div>
      <!-- Filter & Search Controls -->
      <div
        class="bg-surface-container-lowest p-md rounded-xl border border-outline-variant shadow-sm mb-lg flex flex-wrap items-center justify-between gap-md reveal delay-1"
      >
        <div class="flex items-center gap-md flex-1">
          <div class="relative w-full max-w-md">
            <span
              class="material-symbols-outlined absolute left-md top-1/2 -translate-y-1/2 text-outline"
              data-icon="search"
              >search</span
            >
            <input
              id="orderSearchInput"
              class="w-full pl-xl pr-md py-sm bg-surface-container-low border-none rounded-full focus:ring-2 focus:ring-primary-container font-body-md placeholder:text-outline text-on-surface"
              placeholder="Tìm kiếm theo mã đơn, tên khách..."
              type="text"
            />
          </div>
          <div class="flex items-center gap-xs overflow-x-auto pb-xs">
            <button
              id="filterAll"
              onclick="window.filterOrders('')"
              class="px-lg py-xs bg-primary text-on-primary rounded-full text-label-sm shadow-sm hover:shadow-md transition-all"
            >
              Tất cả
            </button>
            <button
              id="filterPending"
              onclick="window.filterOrders('pending')"
              class="px-lg py-xs bg-surface-container-high text-on-surface-variant hover:bg-primary-container/20 rounded-full text-label-sm transition-colors"
            >
              Đang xử lý
            </button>
            <button
              id="filterShipped"
              onclick="window.filterOrders('shipped')"
              class="px-lg py-xs bg-surface-container-high text-on-surface-variant hover:bg-primary-container/20 rounded-full text-label-sm transition-colors"
            >
              Đã giao
            </button>
            <button
              id="filterCancelled"
              onclick="window.filterOrders('cancelled')"
              class="px-lg py-xs bg-surface-container-high text-on-surface-variant hover:bg-primary-container/20 rounded-full text-label-sm transition-colors"
            >
              Đã hủy
            </button>
          </div>
        </div>
        <div class="flex items-center gap-md">
          <button
            class="p-sm text-outline hover:bg-surface-container-high rounded-full transition-colors"
          >
            <span class="material-symbols-outlined" data-icon="filter_list"
              >filter_list</span
            >
          </button>
          <button
            class="p-sm text-outline hover:bg-surface-container-high rounded-full transition-colors"
          >
            <span class="material-symbols-outlined" data-icon="download"
              >download</span
            >
          </button>
        </div>
      </div>
      <!-- Data Table Section -->
      <div
        class="bg-surface-container-lowest rounded-2xl border border-outline-variant shadow-sm overflow-hidden reveal delay-2"
      >
        <table class="w-full text-left border-collapse">
          <thead>
            <tr
              class="bg-surface-container-low border-b border-outline-variant"
            >
              <th
                class="px-lg py-md font-label-md text-on-surface-variant uppercase tracking-wider"
              >
                Mã Đơn hàng
              </th>
              <th
                class="px-lg py-md font-label-md text-on-surface-variant uppercase tracking-wider"
              >
                Khách hàng
              </th>
              <th
                class="px-lg py-md font-label-md text-on-surface-variant uppercase tracking-wider"
              >
                Sản phẩm
              </th>
              <th
                class="px-lg py-md font-label-md text-on-surface-variant uppercase tracking-wider"
              >
                Trạng thái
              </th>
              <th
                class="px-lg py-md font-label-md text-on-surface-variant uppercase tracking-wider"
              >
                Tổng tiền
              </th>
              <th
                class="px-lg py-md font-label-md text-on-surface-variant uppercase tracking-wider text-right"
              >
                Thao tác
              </th>
            </tr>
          </thead>
          <tbody class="divide-y divide-outline-variant" id="orderTableBody">
            <tr class="hover:bg-surface-bright transition-colors group">
              <td
                colspan="6"
                class="px-lg py-md text-center text-on-surface-variant"
              >
                Đang tải dữ liệu...
              </td>
            </tr>
          </tbody>
        </table>
        <!-- Pagination -->
        <div
          class="px-lg py-md bg-surface-container-low border-t border-outline-variant flex items-center justify-between"
        >
          <p id="paginationInfo" class="text-label-sm text-on-surface-variant">
            Đang tải dữ liệu...
          </p>
          <div id="paginationControls" class="flex items-center gap-sm">
            <!-- Dynamic controls here -->
          </div>
        </div>
      </div>
      <!-- Secondary Info Cards (Bento) -->
      <div class="grid grid-cols-12 gap-lg mt-xl">
        <div
          class="col-span-12 bg-surface-container-lowest p-lg rounded-xl border border-outline-variant shadow-sm"
        >
          <div class="flex items-center justify-between mb-lg">
            <h3 class="font-headline-sm text-headline-sm">
              Lịch sử đơn hàng mới nhất
            </h3>
            <a
              class="text-primary font-label-md hover:underline"
              href="/admin/report"
              >Xem báo cáo chi tiết</a
            >
          </div>
          <div class="space-y-md" id="manageOrderRecentHistory">
            <p class="text-on-surface-variant text-center p-md">Đang tải...</p>
          </div>
        </div>
      </div>
    <%- include('../partials/footer') %>
    </main>
      <!-- Order Detail Modal -->
      <div
        id="orderDetailModal"
        class="hidden fixed inset-0 z-[100] flex items-center justify-center p-4"
      >
        <div
          class="absolute inset-0 bg-black/40 backdrop-blur-sm"
          onclick="window.closeOrderDetail()"
        ></div>
        <div
          class="relative bg-surface rounded-2xl w-full max-w-2xl max-h-[90vh] overflow-hidden flex flex-col shadow-2xl"
        >
          <div
            class="p-lg border-b border-outline-variant flex items-center justify-between"
          >
            <h3 class="font-headline-md text-headline-md text-on-surface">
              Chi tiết đơn hàng
              <span id="modalOrderNumber" class="text-primary"></span>
            </h3>
            <button
              onclick="window.closeOrderDetail()"
              class="p-xs hover:bg-surface-variant rounded-full text-on-surface-variant transition-colors flex items-center"
            >
              <span class="material-symbols-outlined">close</span>
            </button>
          </div>
          <div class="p-lg overflow-y-auto space-y-lg flex-1">
            <div class="grid grid-cols-2 gap-lg">
              <div>
                <p class="text-label-sm text-on-surface-variant mb-1">
                  Khách hàng
                </p>
                <p
                  id="modalCustomerName"
                  class="font-label-md text-on-surface"
                ></p>
                <p
                  id="modalCustomerPhone"
                  class="text-body-md text-on-surface mt-1"
                ></p>
              </div>
              <div>
                <p class="text-label-sm text-on-surface-variant mb-1">
                  Trạng thái
                </p>
                <span
                  id="modalOrderStatus"
                  class="px-2 py-1 rounded-full text-xs font-bold mt-1 inline-block"
                ></span>
              </div>
              <div class="col-span-2">
                <p class="text-label-sm text-on-surface-variant mb-1">
                  Địa chỉ giao hàng
                </p>
                <p
                  id="modalCustomerAddress"
                  class="text-body-md text-on-surface"
                ></p>
              </div>
            </div>

            <div>
              <p class="font-label-md text-on-surface mb-md">Sản phẩm</p>
              <div
                class="border border-outline-variant rounded-xl overflow-hidden"
              >
                <table class="w-full text-left">
                  <thead
                    class="bg-surface-container-low border-b border-outline-variant"
                  >
                    <tr>
                      <th
                        class="px-md py-sm text-label-sm text-on-surface-variant uppercase"
                      >
                        Sản phẩm
                      </th>
                      <th
                        class="px-md py-sm text-label-sm text-on-surface-variant uppercase text-right"
                      >
                        SL
                      </th>
                      <th
                        class="px-md py-sm text-label-sm text-on-surface-variant uppercase text-right"
                      >
                        Thành tiền
                      </th>
                    </tr>
                  </thead>
                  <tbody
                    id="modalOrderProducts"
                    class="divide-y divide-outline-variant"
                  ></tbody>
                </table>
              </div>
            </div>

            <div
              class="flex justify-end gap-md mt-lg pt-md border-t border-outline-variant"
            >
              <div class="text-right">
                <p class="text-label-sm text-on-surface-variant">Tổng cộng</p>
                <p
                  id="modalOrderTotal"
                  class="font-headline-md text-primary mt-1"
                ></p>
              </div>
            </div>
          </div>
        </div>
      </div>
    <script type="module">
      import {
        getAdminOrders,
        updateOrderStatus,
        deleteOrder,
        getOrderStats,
        getDashboardStats,
        createAdminOrder,
        getAllUsers,
        getAdminProducts,
      } from "/js/admin.js";
      import { isAuthenticated, getUserInfo } from "/js/auth.js";

      // Check auth
      if (!isAuthenticated() || getUserInfo()?.role !== "admin") {
        window.location.href = "/auth/login";
      }

      // Load dashboard stats
      (async () => {
        const result = await getDashboardStats();
        if (result.success) {
          const d = result.dashboard;
          document.getElementById("statTotalOrders").textContent =
            d.orders?.total?.toLocaleString("vi-VN") || "—";
          document.getElementById("statPendingOrders").textContent =
            d.orders?.pending || "—";

          // Get today's revenue from revenueByDay
          const today = new Date();
          const todayKey = {
            year: today.getFullYear(),
            month: today.getMonth() + 1,
            day: today.getDate(),
          };

          let dailyRevenue = 0;
          if (d.revenueByDay && Array.isArray(d.revenueByDay)) {
            const todayData = d.revenueByDay.find(
              (item) =>
                item._id.year === todayKey.year &&
                item._id.month === todayKey.month &&
                item._id.day === todayKey.day
            );
            dailyRevenue = todayData?.revenue || 0;
          }

          document.getElementById("statDailyRevenue").textContent =
            new Intl.NumberFormat("vi-VN", {
              style: "currency",
              currency: "VND",
            }).format(dailyRevenue);
        }
      })();

      let currentPage = 1;
      const pageSize = 10;

      function renderRecentHistory(orders) {
        const container = document.getElementById("manageOrderRecentHistory");
        if (!container) return;
        if (!orders || orders.length === 0) {
          container.innerHTML =
            '<p class="text-on-surface-variant text-center p-md">Không có dữ liệu</p>';
          return;
        }

        const recent = orders.slice(0, 4);
        container.innerHTML = recent
          .map((order) => {
            const customerName =
              order.user?.fullName ||
              order.user?.email ||
              order.shippingAddress?.phone ||
              "Khách ẩn danh";
            const formattedPrice = new Intl.NumberFormat("vi-VN", {
              style: "currency",
              currency: "VND",
            }).format(order.totalPrice);
            const dateStr = order.createdAt
              ? new Date(order.createdAt).toLocaleDateString("vi-VN")
              : "Vừa xong";

            return `
            <div class="flex items-center justify-between p-sm hover:bg-surface-container-low rounded-lg transition-colors">
              <div class="flex items-center gap-md">
                <div class="w-10 h-10 rounded-full bg-primary-container text-on-primary-container flex items-center justify-center font-bold">
                  <span class="material-symbols-outlined text-[20px]">receipt_long</span>
                </div>
                <div>
                  <p class="font-label-md text-on-surface">${order.orderNumber}</p>
                  <p class="text-xs text-on-surface-variant">${customerName} • ${dateStr}</p>
                </div>
              </div>
              <div class="text-right">
                <p class="font-label-md text-primary">${formattedPrice}</p>
                <p class="text-[10px] text-on-surface-variant uppercase font-bold">${order.status}</p>
              </div>
            </div>
          `;
          })
          .join("");
      }

      let currentFilter = "";
      window.currentOrders = [];

      window.loadOrders = async function (page = 1, status = "") {
        currentPage = page;
        const orderTableBody = document.getElementById("orderTableBody");
        const paginationInfo = document.getElementById("paginationInfo");
        const paginationControls =
          document.getElementById("paginationControls");

        const queryStatus =
          status !== undefined && status !== "" ? status : currentFilter;
        const result = await getAdminOrders({
          page,
          limit: pageSize,
          status: queryStatus,
        });
        if (result.success) {
          const orders = result.orders;
          window.currentOrders = orders;
          const totalOrders =
            result.pagination?.total ||
            result.total ||
            (orders.length < pageSize && page === 1
              ? orders.length
              : page * pageSize + 1);
          const totalPages =
            result.pagination?.pages ||
            result.totalPages ||
            Math.ceil(totalOrders / pageSize) ||
            1;

          if (page === 1) renderRecentHistory(orders);

          if (!orders || orders.length === 0) {
            orderTableBody.innerHTML =
              '<tr><td colspan="6" class="px-lg py-md text-center text-on-surface-variant">Không có đơn hàng nào.</td></tr>';
            if (paginationInfo) paginationInfo.textContent = "Không có dữ liệu";
            if (paginationControls) paginationControls.innerHTML = "";
            return;
          }

          orderTableBody.innerHTML = orders
            .map((order) => {
              const customerName =
                order.user?.fullName ||
                order.user?.email ||
                order.shippingAddress?.phone ||
                "Khách ẩn danh";
              const productCount = order.products?.length || 0;
              const statusMap = {
                pending: {
                  label: "Chờ xử lý",
                  class: "bg-primary-container text-on-primary-container",
                },
                confirmed: {
                  label: "Đã xác nhận",
                  class: "bg-tertiary-container text-on-tertiary-container",
                },
                shipped: {
                  label: "Đang giao",
                  class: "bg-blue-100 text-blue-800",
                },
                delivered: {
                  label: "Đã giao",
                  class: "bg-green-100 text-green-800",
                },
                cancelled: {
                  label: "Đã hủy",
                  class: "bg-error-container text-on-error-container",
                },
              };
              const statusInfo = statusMap[order.status] || {
                label: order.status,
                class: "bg-surface-variant text-on-surface-variant",
              };

              const formattedPrice = new Intl.NumberFormat("vi-VN", {
                style: "currency",
                currency: "VND",
              }).format(order.totalPrice);

              return `
              <tr class="hover:bg-surface-bright transition-colors group border-b border-outline-variant/30">
                <td class="px-lg py-md text-label-md font-bold text-primary">${order.orderNumber}</td>
                <td class="px-lg py-md text-body-md text-on-surface">${customerName}</td>
                <td class="px-lg py-md text-body-md text-on-surface-variant">${productCount} sản phẩm</td>
                <td class="px-lg py-md">
                  <span class="px-2 py-1 rounded-full text-xs font-bold ${statusInfo.class}">${statusInfo.label}</span>
                </td>
                <td class="px-lg py-md text-label-md text-on-surface">${formattedPrice}</td>
                <td class="px-lg py-md">
                   <div class="flex items-center justify-end gap-2">
                     <select onchange="window.updateOrder('${order._id}', this.value)" class="text-sm border-outline-variant rounded-md bg-surface-container text-on-surface py-1 pl-3 pr-8 focus:ring-primary focus:border-primary">
                       <option value="pending" ${order.status === "pending" ? "selected" : ""}>Chờ xử lý</option>
                       <option value="confirmed" ${order.status === "confirmed" ? "selected" : ""}>Xác nhận</option>
                       <option value="shipped" ${order.status === "shipped" ? "selected" : ""}>Giao hàng</option>
                       <option value="delivered" ${order.status === "delivered" ? "selected" : ""}>Đã giao</option>
                       <option value="cancelled" ${order.status === "cancelled" ? "selected" : ""}>Hủy</option>
                     </select>
                     <button type="button" onclick="window.openOrderDetail('${order._id}')" class="w-8 h-8 flex items-center justify-center rounded-full bg-surface-container-high text-on-surface hover:text-primary transition-colors hover:bg-primary-container/20" title="Xem chi tiết">
                       <span class="material-symbols-outlined text-[18px]">visibility</span>
                     </button>
                     <button type="button" onclick="window.deleteOrder('${order._id}')" class="w-8 h-8 flex items-center justify-center rounded-full bg-error-container text-on-error-container hover:bg-error/90 transition-colors" title="Xóa đơn">
                       <span class="material-symbols-outlined text-[18px]">delete</span>
                     </button>
                   </div>
                </td>
              </tr>
             `;
            })
            .join("");

          if (paginationInfo) {
            const start = (page - 1) * pageSize + 1;
            const end = Math.min(page * pageSize, totalOrders);
            paginationInfo.textContent = `Hiển thị ${start} - ${end} của ${totalOrders} đơn hàng`;
          }

          if (paginationControls) {
            let controlsHTML = `
                <button onclick="window.loadOrders(${page - 1})" class="p-xs text-outline hover:bg-surface-variant rounded-md disabled:opacity-30" ${page <= 1 ? "disabled" : ""}>
                  <span class="material-symbols-outlined" data-icon="chevron_left">chevron_left</span>
                </button>
             `;

            for (let i = 1; i <= totalPages; i++) {
              if (i === page) {
                controlsHTML += `<button class="w-8 h-8 rounded-md bg-primary text-on-primary font-bold text-label-sm">${i}</button>`;
              } else {
                controlsHTML += `<button onclick="window.loadOrders(${i})" class="w-8 h-8 rounded-md hover:bg-surface-variant text-on-surface text-label-sm transition-colors">${i}</button>`;
              }
            }

            controlsHTML += `
                <button onclick="window.loadOrders(${page + 1})" class="p-xs text-outline hover:bg-surface-variant rounded-md disabled:opacity-30" ${page >= totalPages ? "disabled" : ""}>
                  <span class="material-symbols-outlined" data-icon="chevron_right">chevron_right</span>
                </button>
             `;
            paginationControls.innerHTML = controlsHTML;
          }
        } else {
          orderTableBody.innerHTML =
            '<tr><td colspan="6" class="px-lg py-md text-center text-error">Lỗi khi tải dữ liệu.</td></tr>';
        }

        // Re-trigger scroll reveal and other animations on newly loaded order table rows
        if (window.XamAnimations) {
          window.XamAnimations.init();
        }
      };

      window.loadOrders();

      window.filterOrders = function (status) {
        currentFilter = status;

        // Update button styles
        const buttons = {
          "": "filterAll",
          pending: "filterPending",
          shipped: "filterShipped",
          cancelled: "filterCancelled",
        };

        Object.entries(buttons).forEach(([key, btnId]) => {
          const btn = document.getElementById(btnId);
          if (btn) {
            if (key === status) {
              btn.className =
                "px-lg py-xs bg-primary text-on-primary rounded-full text-label-sm shadow-sm hover:shadow-md transition-all";
            } else {
              btn.className =
                "px-lg py-xs bg-surface-container-high text-on-surface-variant hover:bg-primary-container/20 rounded-full text-label-sm transition-colors";
            }
          }
        });

        currentPage = 1;
        window.loadOrders(1, status);
      };

      // Search functionality
      const searchInput = document.getElementById("orderSearchInput");
