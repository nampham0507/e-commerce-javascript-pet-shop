              </div>
              <div class="flex gap-sm">
                <button id="cancelCreateOrderBtn" type="button" class="px-lg py-sm bg-surface-container-high rounded-full">Hủy</button>
                <button id="submitCreateOrderBtn" type="button" class="px-lg py-sm bg-primary text-on-primary rounded-full">Tạo đơn</button>
              </div>
