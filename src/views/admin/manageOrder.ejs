      window.openOrderDetail = function (orderId) {
        const order = window.currentOrders.find((o) => o._id === orderId);
        if (!order) return;

        document.getElementById("modalOrderNumber").textContent =
          order.orderNumber;
        document.getElementById("modalCustomerName").textContent =
          order.user?.fullName ||
          order.user?.email ||
          order.shippingAddress?.fullName ||
          "Khách ẩn danh";
        document.getElementById("modalCustomerPhone").textContent =
          order.shippingAddress?.phone || "";

        const address = order.shippingAddress;
        const addressParts = [address?.address, address?.city].filter(Boolean);
        document.getElementById("modalCustomerAddress").textContent =
          addressParts.length > 0 ? addressParts.join(", ") : "Chưa cập nhật";

        const statusMap = {
          pending: {
            label: "Chờ xử lý",
            class: "bg-primary-container text-on-primary-container",
          },
          confirmed: {
            label: "Đã xác nhận",
            class: "bg-tertiary-container text-on-tertiary-container",
          },
          shipped: { label: "Đang giao", class: "bg-blue-100 text-blue-800" },
          delivered: { label: "Đã giao", class: "bg-green-100 text-green-800" },
          cancelled: {
            label: "Đã hủy",
            class: "bg-error-container text-on-error-container",
          },
        };
        const statusInfo = statusMap[order.status] || {
          label: order.status,
          class: "bg-surface-variant text-on-surface-variant",
        };

        const statusEl = document.getElementById("modalOrderStatus");
        statusEl.textContent = statusInfo.label;
        statusEl.className = `px-2 py-1 rounded-full text-xs font-bold mt-1 inline-block ${statusInfo.class}`;

        const productsHtml = (order.products || [])
          .map((p) => {
            const price = p.product?.price || 0;
            const qty = p.quantity || 1;
            const fmtPrice = new Intl.NumberFormat("vi-VN", {
              style: "currency",
              currency: "VND",
            }).format(price * qty);
            return `
             <tr class="hover:bg-surface-bright transition-colors">
               <td class="px-md py-sm text-body-md text-on-surface">${p.product?.name || "Sản phẩm"}</td>
               <td class="px-md py-sm text-body-md text-on-surface-variant text-right">${qty}</td>
               <td class="px-md py-sm text-label-md text-on-surface text-right">${fmtPrice}</td>
             </tr>
           `;
          })
          .join("");
        document.getElementById("modalOrderProducts").innerHTML =
          productsHtml ||
          '<tr><td colspan="3" class="text-center py-2 text-on-surface-variant">Không có sản phẩm</td></tr>';

        document.getElementById("modalOrderTotal").textContent =
          new Intl.NumberFormat("vi-VN", {
            style: "currency",
            currency: "VND",
          }).format(order.totalPrice);

        const modal = document.getElementById("orderDetailModal");
        modal.classList.remove("hidden");
