            const customerName = (
              order.user?.fullName ||
              order.user?.email ||
              order.shippingAddress?.fullName ||
              ""
            ).toLowerCase();
            return (
              orderNumber.includes(searchTerm) ||
              customerName.includes(searchTerm)
            );
          });

          if (filtered.length === 0) {
            orderTableBody.innerHTML =
              '<tr><td colspan="6" class="px-lg py-md text-center text-outline-variant">Không tìm thấy đơn hàng</td></tr>';
