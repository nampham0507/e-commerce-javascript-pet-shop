  </head>
  <body class="font-body-md text-body-md">
    <%- include('../partials/admin-sidebar', { activePage: 'products' }) %>
    <!-- Main Content Canvas -->
    <main class="ml-64 p-xl min-h-screen">
      <!-- Header Actions Section -->
      <header
        class="flex flex-col md:flex-row justify-between items-start md:items-center mb-xl gap-md"
      >
        <div>
          <h2 class="font-headline-lg text-headline-lg text-on-surface section-heading">
            Quản Lý Sản Phẩm
          </h2>

        </div>
        <button
          id="addProductBtn"
          class="bg-primary-container text-on-primary-container font-label-md text-label-md px-lg py-3 rounded-full flex items-center gap-2 hover:scale-105 transition-transform shadow-md active:scale-95 btn-ripple"
        >
          <span class="material-symbols-outlined">add</span>
          Thêm Sản Phẩm
        </button>
      </header>
      <!-- Filters and Search -->
      <div
        class="bg-white rounded-[24px] p-md mb-lg border border-outline-variant soft-shadow flex flex-wrap items-center gap-md reveal delay-1"
      >
        <div class="flex-1 min-w-[300px] relative">
          <span
            class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline"
            >search</span
          >
          <input
            class="w-full bg-surface-container-low border-none rounded-full py-3 pl-12 pr-4 focus:ring-2 focus:ring-primary-container font-body-md text-body-md"
            placeholder="Tìm kiếm sản phẩm theo tên..."
            type="text"
          />
        </div>
        <select
          id="tableCategoryFilter"
          class="bg-surface-container-low border-none rounded-full py-3 px-lg focus:ring-2 focus:ring-primary-container font-label-md text-label-md text-on-surface-variant"
        >
          <option value="">Tất cả danh mục</option>
        </select>
        <button
          class="p-3 bg-surface-container-low rounded-full text-on-surface-variant hover:bg-secondary-container transition-colors"
        >
          <span class="material-symbols-outlined">filter_list</span>
        </button>
      </div>
      <!-- Products Table -->
      <div
        class="bg-white rounded-[24px] border border-outline-variant soft-shadow overflow-hidden reveal"
      >
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead class="bg-surface-container-low">
              <tr>
                <th
                  class="px-lg py-md font-label-md text-label-md text-on-surface-variant uppercase tracking-wider"
                >
                  Hình ảnh
                </th>
                <th
                  class="px-lg py-md font-label-md text-label-md text-on-surface-variant uppercase tracking-wider"
                >
                  Tên Sản Phẩm
                </th>
                <th
                  class="px-lg py-md font-label-md text-label-md text-on-surface-variant uppercase tracking-wider"
                >
                  Danh mục
                </th>
                <th
                  class="px-lg py-md font-label-md text-label-md text-on-surface-variant uppercase tracking-wider"
                >
                  Giá Bán
                </th>
                <th
                  class="px-lg py-md font-label-md text-label-md text-on-surface-variant uppercase tracking-wider"
                >
                  Tồn kho
                </th>
                <th
                  class="px-lg py-md font-label-md text-label-md text-on-surface-variant uppercase tracking-wider text-right"
                >
                  Thao tác
                </th>
              </tr>
            </thead>
            <tbody
              id="productsTableBody"
              class="divide-y divide-outline-variant"
            >
              <!-- Product rows will be rendered here dynamically -->
              <tr class="table-row-hover transition-colors">
                <td colspan="6" class="px-lg py-xl text-center">
                  <p class="text-on-surface-variant">Đang tải sản phẩm...</p>
                </td>
              </tr>
            </tbody>
          </table>
        </div>
        <!-- Pagination -->
        <div
          class="px-lg py-md bg-surface-container-low flex justify-between items-center"
        >
          <span class="text-label-sm text-on-surface-variant"
            >Hiển thị <span id="productCountStart">0</span> -
            <span id="productCountEnd">0</span> trên
            <span id="totalProductsFooter">0</span> sản phẩm</span
          >
          <div class="flex gap-2">
            <button
              class="p-2 rounded-full hover:bg-surface-container-high text-on-surface-variant disabled:opacity-30"
              id="prevPageBtn"
              disabled=""
            >
              <span class="material-symbols-outlined">chevron_left</span>
            </button>
            <div id="paginationContainer" class="flex gap-2">
              <!-- Page buttons will be rendered here -->
            </div>
            <button
              class="p-2 rounded-full hover:bg-surface-container-high text-on-surface-variant"
              id="nextPageBtn"
            >
              <span class="material-symbols-outlined">chevron_right</span>
            </button>
          </div>
        </div>

    <%- include('../partials/footer') %>
    </main>

    <!-- Modal for Add/Edit Product -->
    <div
      id="productModal"
      class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-lg"
    >
      <div
        class="bg-white rounded-[32px] w-full max-w-2xl max-h-[90vh] overflow-y-auto shadow-xl"
      >
        <div
          class="sticky top-0 bg-white px-xl py-lg border-b border-outline-variant flex items-center justify-between"
        >
          <h3
            id="modalTitle"
            class="font-headline-lg text-headline-lg text-on-surface"
          >
            Thêm Sản Phẩm
          </h3>
          <button
            id="closeModalBtn"
            class="p-2 text-on-surface-variant hover:text-on-surface transition-colors"
          >
            <span class="material-symbols-outlined">close</span>
          </button>
        </div>

        <form id="productForm" class="p-xl space-y-lg">
          <input type="hidden" id="productId" />

          <div class="grid grid-cols-1 md:grid-cols-2 gap-lg">
            <div>
              <label
                class="block font-label-md text-label-md text-on-surface mb-sm"
              >
                Tên Sản Phẩm *
              </label>
              <input
                id="productName"
                type="text"
                class="w-full bg-surface-container-low border-none rounded-full px-lg py-md focus:ring-2 focus:ring-primary-container outline-none"
                placeholder="Nhập tên sản phẩm"
                required
              />
            </div>

            <div>
              <label
                class="block font-label-md text-label-md text-on-surface mb-sm"
              >
                Thương Hiệu *
              </label>
              <select
                id="productBrand"
                class="w-full bg-surface-container-low border-none rounded-full px-lg py-md focus:ring-2 focus:ring-primary-container outline-none"
                required
              >
                <option value="">Chọn thương hiệu</option>
              </select>
            </div>

            <div>
              <label
                class="block font-label-md text-label-md text-on-surface mb-sm"
              >
                Danh Mục *
              </label>
              <select
                id="productCategory"
                class="w-full bg-surface-container-low border-none rounded-full px-lg py-md focus:ring-2 focus:ring-primary-container outline-none"
                required
              >
                <option value="">Chọn danh mục</option>
              </select>
            </div>

            <div>
              <label
                class="block font-label-md text-label-md text-on-surface mb-sm"
              >
                Giá Bán (VND) *
              </label>
              <input
                id="productPrice"
                type="number"
                class="w-full bg-surface-container-low border-none rounded-full px-lg py-md focus:ring-2 focus:ring-primary-container outline-none"
                placeholder="0"
                min="0"
                required
              />
            </div>

            <div>
              <label
                class="block font-label-md text-label-md text-on-surface mb-sm"
              >
                Tồn Kho (Số Lượng) *
              </label>
              <input
                id="productQuantity"
                type="number"
                class="w-full bg-surface-container-low border-none rounded-full px-lg py-md focus:ring-2 focus:ring-primary-container outline-none"
                placeholder="0"
                min="0"
                required
              />
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-lg">
            <!-- Đã gộp Thương hiệu vào Danh mục -->
            <div>
              <label class="block font-label-md text-label-md text-on-surface mb-sm">Trọng lượng</label>
              <input id="productWeight" type="text" class="w-full bg-surface-container-low border-none rounded-full px-lg py-md focus:ring-2 focus:ring-primary-container outline-none" placeholder="VD: 2kg" />
            </div>
            <div>
              <label class="block font-label-md text-label-md text-on-surface mb-sm">Giai đoạn sống (Life Stage)</label>
              <input id="productLifeStage" type="text" class="w-full bg-surface-container-low border-none rounded-full px-lg py-md focus:ring-2 focus:ring-primary-container outline-none" placeholder="VD: Adult Cats" />
            </div>
            <div>
              <label class="block font-label-md text-label-md text-on-surface mb-sm">Hương vị</label>
              <input id="productFlavor" type="text" class="w-full bg-surface-container-low border-none rounded-full px-lg py-md focus:ring-2 focus:ring-primary-container outline-none" placeholder="VD: Cá hồi" />
            </div>
            <div>
              <label class="block font-label-md text-label-md text-on-surface mb-sm">Xuất xứ</label>
              <input id="productOrigin" type="text" class="w-full bg-surface-container-low border-none rounded-full px-lg py-md focus:ring-2 focus:ring-primary-container outline-none" placeholder="VD: Pháp" />
            </div>
            <div>
              <label class="block font-label-md text-label-md text-on-surface mb-sm">Lợi ích (cách nhau bởi dấu phẩy)</label>
              <input id="productBenefits" type="text" class="w-full bg-surface-container-low border-none rounded-full px-lg py-md focus:ring-2 focus:ring-primary-container outline-none" placeholder="VD: Sạch răng, Mượt lông" />
            </div>
          </div>

          <div>
            <label class="block font-label-md text-label-md text-on-surface mb-sm">Thành phần (cách nhau bởi dấu phẩy)</label>
            <textarea id="productIngredients" class="w-full bg-surface-container-low border-none rounded-lg px-lg py-md focus:ring-2 focus:ring-primary-container outline-none" placeholder="VD: Cá hồi 50%, Vitamin E..." rows="2"></textarea>
          </div>

          <div>
            <label class="block font-label-md text-label-md text-on-surface mb-sm">Mô tả ngắn</label>
            <textarea id="productDescription" class="w-full bg-surface-container-low border-none rounded-lg px-lg py-md focus:ring-2 focus:ring-primary-container outline-none" placeholder="Nhập mô tả ngắn sản phẩm" rows="3"></textarea>
          </div>

          <div>
            <label class="block font-label-md text-label-md text-on-surface mb-sm">Mô tả chi tiết</label>
            <textarea id="productDetailedDescription" class="w-full bg-surface-container-low border-none rounded-lg px-lg py-md focus:ring-2 focus:ring-primary-container outline-none" placeholder="Mô tả chi tiết cho tab chi tiết" rows="5"></textarea>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-lg">
            <div>
              <label class="block font-label-md text-label-md text-on-surface mb-sm">Link Hình Ảnh</label>
              <input id="productImage" type="url" class="w-full bg-surface-container-low border-none rounded-full px-lg py-md focus:ring-2 focus:ring-primary-container outline-none" placeholder="https://..." />
            </div>
            <div>
              <label class="block font-label-md text-label-md text-on-surface mb-sm">Tải ảnh từ máy tính</label>
              <input id="productImageFile" type="file" accept="image/*" class="w-full bg-surface-container-low border-none rounded-full px-lg py-2 focus:ring-2 focus:ring-primary-container outline-none text-body-sm" />
              <p id="currentImageText" class="mt-xs text-xs text-primary hidden"></p>
            </div>
          </div>

          <div class="flex gap-md pt-lg">
            <button
              type="submit"
              id="submitBtn"
              class="flex-1 bg-primary text-on-primary font-label-md px-lg py-md rounded-full hover:scale-105 transition-transform shadow-md active:scale-95 btn-ripple"
            >
              Lưu Sản Phẩm
            </button>
            <button
              type="button"
              id="cancelBtn"
              class="flex-1 bg-surface-container-high text-on-surface font-label-md px-lg py-md rounded-full hover:bg-surface-container-highest transition-colors"
            >
              Hủy
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- Modal for Add/Edit Category -->
    <div id="categoryModal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-lg">
      <div class="bg-white rounded-[32px] w-full max-w-md shadow-xl overflow-hidden">
        <div class="sticky top-0 bg-white px-xl py-lg border-b border-outline-variant flex items-center justify-between">
          <h3 id="categoryModalTitle" class="font-headline-lg text-headline-lg text-on-surface">Thêm danh mục</h3>
          <button id="closeCategoryModalBtn" class="p-2 text-on-surface-variant hover:text-on-surface transition-colors">
            <span class="material-symbols-outlined">close</span>
          </button>
        </div>
        <form id="categoryForm" class="p-xl space-y-lg">
          <input type="hidden" id="categoryId" />
          <div>
            <label class="block font-label-md text-label-md text-on-surface mb-sm">Tên danh mục</label>
            <input id="categoryName" type="text" class="w-full bg-surface-container-low border-none rounded-full px-lg py-md focus:ring-2 focus:ring-primary-container outline-none" placeholder="Nhập tên danh mục" required />
          </div>
          <div class="flex gap-md pt-lg">
            <button type="submit" class="flex-1 bg-primary text-on-primary font-label-md px-lg py-md rounded-full hover:scale-105 transition-transform shadow-md active:scale-95 btn-ripple">Lưu danh mục</button>
            <button type="button" id="cancelCategoryBtn" class="flex-1 bg-surface-container-high text-on-surface font-label-md px-lg py-md rounded-full hover:bg-surface-container-highest transition-colors">Hủy</button>
          </div>
        </form>
      </div>
    </div>

    <!-- Modal for Add/Edit Brand -->
    <div id="brandModal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-lg">
      <div class="bg-white rounded-[32px] w-full max-w-md shadow-xl overflow-hidden">
        <div class="sticky top-0 bg-white px-xl py-lg border-b border-outline-variant flex items-center justify-between">
          <h3 id="brandModalTitle" class="font-headline-lg text-headline-lg text-on-surface">Thêm thương hiệu</h3>
          <button id="closeBrandModalBtn" class="p-2 text-on-surface-variant hover:text-on-surface transition-colors">
            <span class="material-symbols-outlined">close</span>
          </button>
        </div>
        <form id="brandForm" class="p-xl space-y-lg">
          <input type="hidden" id="brandId" />
          <div>
            <label class="block font-label-md text-label-md text-on-surface mb-sm">Tên thương hiệu</label>
            <input id="brandName" type="text" class="w-full bg-surface-container-low border-none rounded-full px-lg py-md focus:ring-2 focus:ring-primary-container outline-none" placeholder="Nhập tên thương hiệu" required />
          </div>
          <div class="flex gap-md pt-lg">
            <button type="submit" class="flex-1 bg-primary text-on-primary font-label-md px-lg py-md rounded-full hover:scale-105 transition-transform shadow-md active:scale-95 btn-ripple">Lưu thương hiệu</button>
            <button type="button" id="cancelBrandBtn" class="flex-1 bg-surface-container-high text-on-surface font-label-md px-lg py-md rounded-full hover:bg-surface-container-highest transition-colors">Hủy</button>
          </div>
        </form>
      </div>
    </div>

    <script type="module">
      import {
        getAdminProducts,
        createProduct,
        updateProduct,
        deleteProduct,
        getAdminCategories,
        getAdminBrands,
        createCategory,
        updateCategory,
        deleteCategory,
        createBrand,
        updateBrand,
        deleteBrand,
      } from "/js/admin.js";
      import { logoutUser, getUserInfo, isAuthenticated } from "/js/auth.js";

      // Check auth
      if (!isAuthenticated() || getUserInfo()?.role !== "admin") {
        window.location.href = "/auth/login";
      }

      // DOM Elements
      const addProductBtn = document.getElementById("addProductBtn");
      const productModal = document.getElementById("productModal");
      const closeModalBtn = document.getElementById("closeModalBtn");
      const cancelBtn = document.getElementById("cancelBtn");
      const productForm = document.getElementById("productForm");
      const modalTitle = document.getElementById("modalTitle");
      const submitBtn = document.getElementById("submitBtn");
      const productsTableBody = document.getElementById("productsTableBody");
      const searchInput = document.querySelector(
        'input[placeholder*="Tìm kiếm"]',
      );
      const categorySelect = document.getElementById("tableCategoryFilter");
      const categoryModal = document.getElementById("categoryModal");
      const brandModal = document.getElementById("brandModal");
      const closeCategoryModalBtn = document.getElementById("closeCategoryModalBtn");
      const cancelCategoryBtn = document.getElementById("cancelCategoryBtn");
      const categoryForm = document.getElementById("categoryForm");
      const categoryModalTitle = document.getElementById("categoryModalTitle");
      const categoryNameInput = document.getElementById("categoryName");
      const categoryIdInput = document.getElementById("categoryId");
      const closeBrandModalBtn = document.getElementById("closeBrandModalBtn");
      const cancelBrandBtn = document.getElementById("cancelBrandBtn");
      const brandForm = document.getElementById("brandForm");
      const brandModalTitle = document.getElementById("brandModalTitle");
      const brandNameInput = document.getElementById("brandName");
      const brandIdInput = document.getElementById("brandId");
      const paginationContainer = document.getElementById(
        "paginationContainer",
      );
      const prevPageBtn = document.getElementById("prevPageBtn");
      const nextPageBtn = document.getElementById("nextPageBtn");

      let currentPage = 1;
      let currentFilters = {};
      let editingProductId = null;
      let totalPages = 1;
      let totalProducts = 0;

      // Update pagination UI
      function updatePaginationUI(pagination) {
        if (!pagination) return;

        totalPages = pagination.pages;
        totalProducts = pagination.total;

        // Update display text
        const startNum = (pagination.page - 1) * pagination.limit + 1;
        const endNum = Math.min(
          pagination.page * pagination.limit,
          pagination.total,
        );

        document.getElementById("productCountStart").textContent = startNum;
        document.getElementById("productCountEnd").textContent = endNum;
        document.getElementById("totalProductsFooter").textContent =
          pagination.total;

        // Render page buttons
        paginationContainer.innerHTML = "";
        for (let i = 1; i <= totalPages; i++) {
          const btn = document.createElement("button");
          btn.className =
            i === currentPage
              ? "w-10 h-10 rounded-full bg-primary-container text-on-primary-container font-label-md flex items-center justify-center"
              : "w-10 h-10 rounded-full hover:bg-surface-container-high text-on-surface-variant font-label-md flex items-center justify-center";
          btn.textContent = i;
          btn.addEventListener("click", () => goToPage(i));
          paginationContainer.appendChild(btn);
        }

        // Update prev/next button states
        prevPageBtn.disabled = currentPage === 1;
        nextPageBtn.disabled = currentPage === totalPages;
      }

      // Go to specific page
      function goToPage(page) {
        if (page < 1 || page > totalPages) return;
        currentPage = page;
        loadProducts();
      }

      // Format currency
      function formatPrice(price) {
        return new Intl.NumberFormat("vi-VN", {
          style: "currency",
          currency: "VND",
          minimumFractionDigits: 0,
        }).format(price);
      }

      // Render product row
      function renderProductRow(product) {
        const stockStatus =
          product.quantity < 10
            ? `<span class="w-2 h-2 rounded-full bg-error"></span><span class="font-body-md text-body-md text-error">${product.quantity} (Sắp hết)</span>`
            : `<span class="w-2 h-2 rounded-full bg-tertiary"></span><span class="font-body-md text-body-md">${product.quantity}</span>`;

        return `
          <tr class="table-row-hover transition-colors">
            <td class="px-lg py-md">
              <div class="w-16 h-16 rounded-xl overflow-hidden bg-surface-container-highest border border-outline-variant">
                <img
                  class="w-full h-full object-cover"
                  src="${product.image || "https://via.placeholder.com/64?text=No+Image"}"
                  alt="${product.name}"
                />
              </div>
            </td>
            <td class="px-lg py-md">
              <div class="flex flex-col">
                <span class="font-label-md text-label-md text-on-surface">${product.name}</span>
                <span class="text-label-sm text-on-surface-variant">ID: ${product._id.substring(0, 8)}</span>
              </div>
            </td>
            <td class="px-lg py-md">
              <span class="px-3 py-1 rounded-full bg-secondary-container text-on-secondary-container text-label-sm font-bold uppercase">
                ${product.category}
              </span>
            </td>
            <td class="px-lg py-md">
              <span class="font-label-md text-label-md text-primary">${formatPrice(product.price)}</span>
            </td>
            <td class="px-lg py-md">
              <div class="flex items-center gap-2">
                ${stockStatus}
              </div>
            </td>
            <td class="px-lg py-md text-right">
              <div class="flex justify-end gap-2">
                <button
                  class="p-2 text-on-surface-variant hover:text-primary transition-colors hover:bg-primary-container/10 rounded-full edit-btn"
                  data-id="${product._id}"
                >
                  <span class="material-symbols-outlined">edit</span>
                </button>
                <button
                  class="p-2 text-on-surface-variant hover:text-error transition-colors hover:bg-error-container/20 rounded-full delete-btn"
                  data-id="${product._id}"
                  data-name="${product.name}"
                >
                  <span class="material-symbols-outlined">delete</span>
                </button>
              </div>
            </td>
          </tr>
        `;
      }

      // Load and render products
      async function loadProducts() {
        try {
          const result = await getAdminProducts({
            page: currentPage,
            limit: 10,
            ...currentFilters,
          });

          if (result && result.success && result.products) {
            if (result.products.length === 0) {
              productsTableBody.innerHTML = `
                <tr>
                  <td colspan="6" class="px-lg py-xl text-center">
                    <p class="text-on-surface-variant">Không tìm thấy sản phẩm nào</p>
                  </td>
                </tr>
              `;
              updatePaginationUI(result.pagination);
            } else {
              productsTableBody.innerHTML = result.products
                .map(renderProductRow)
                .join("");
              attachRowEventListeners();
              updatePaginationUI(result.pagination);
            }
          } else {
            productsTableBody.innerHTML = `
              <tr>
                <td colspan="6" class="px-lg py-xl text-center">
                  <p class="text-error">Lỗi tải dữ liệu: ${result?.message || "Lỗi không xác định"}</p>
                </td>
              </tr>
            `;
            if (result?.message === "Invalid token" || result?.message === "No token provided") {
              alert("Phiên đăng nhập đã hết hạn. Vui lòng đăng nhập lại.");
              localStorage.removeItem("token");
              localStorage.removeItem("user");
              window.location.href = "/auth/login";
            }
          }
        } catch (error) {
          productsTableBody.innerHTML = `
            <tr>
              <td colspan="6" class="px-lg py-xl text-center">
                <p class="text-error">Lỗi kết nối: ${error.message}</p>
              </td>
            </tr>
          `;
        }
      }

      // Attach event listeners to edit and delete buttons
      function attachRowEventListeners() {
        // Edit buttons
        document.querySelectorAll(".edit-btn").forEach((btn) => {
          btn.addEventListener("click", async () => {
            const productId = btn.dataset.id;
            const response = await fetch(
              `http://localhost:5000/api/products/${productId}`,
            );
            const product = await response.json();
            openEditModal(product);
          });
        });

        // Delete buttons
        document.querySelectorAll(".delete-btn").forEach((btn) => {
          btn.addEventListener("click", async () => {
            const productId = btn.dataset.id;
            const productName = btn.dataset.name;
            if (confirm(`Bạn có chắc chắn muốn xóa "${productName}"?`)) {
              const result = await deleteProduct(productId);
              if (result.success) {
                alert(result.message || "Xóa sản phẩm thành công");
                loadProducts();
              } else {
                alert(result.message || "Lỗi khi xóa sản phẩm");
              }
            }
          });
        });
      }

      const categoryOptionsCache = new Map();
      const brandOptionsCache = new Map();

      const renderCategoryRow = (category) => `
        <tr class="table-row-hover transition-colors">
          <td class="px-lg py-md">${category.name}</td>
          <td class="px-lg py-md text-right">
            <div class="flex justify-end gap-2">
              <button data-id="${category._id}" data-name="${category.name}" class="p-2 text-on-surface-variant hover:text-primary transition-colors hover:bg-primary-container/10 rounded-full edit-category-btn">
                <span class="material-symbols-outlined">edit</span>
              </button>
              <button data-id="${category._id}" data-name="${category.name}" class="p-2 text-on-surface-variant hover:text-error transition-colors hover:bg-error-container/20 rounded-full delete-category-btn">
                <span class="material-symbols-outlined">delete</span>
              </button>
            </div>
          </td>
        </tr>
      `;

      const renderBrandRow = (brand) => `
        <tr class="table-row-hover transition-colors">
          <td class="px-lg py-md">${brand.name}</td>
          <td class="px-lg py-md text-right">
            <div class="flex justify-end gap-2">
              <button data-id="${brand._id}" data-name="${brand.name}" class="p-2 text-on-surface-variant hover:text-primary transition-colors hover:bg-primary-container/10 rounded-full edit-brand-btn">
                <span class="material-symbols-outlined">edit</span>
              </button>
              <button data-id="${brand._id}" data-name="${brand.name}" class="p-2 text-on-surface-variant hover:text-error transition-colors hover:bg-error-container/20 rounded-full delete-brand-btn">
                <span class="material-symbols-outlined">delete</span>
              </button>
            </div>
          </td>
        </tr>
      `;

      let brandSelectInstance = null;
      let categorySelectInstance = null;

      const populateBrandSelect = (brands) => {
        const select = document.getElementById("productBrand");
        if (!select) return;
        if (brandSelectInstance) brandSelectInstance.destroy();
        select.innerHTML = `<option value="">Chọn thương hiệu</option>${brands
          .map((item) => `<option value="${item.name}">${item.name}</option>`)
          .join("")}`;
        brandSelectInstance = new TomSelect("#productBrand", {
          create: false,
          sortField: { field: "text", direction: "asc" },
          placeholder: "Tìm kiếm thương hiệu...",
        });
      };

      const populateCategorySelect = (categories) => {
        const select = document.getElementById("productCategory");
        if (!select) return;
        if (categorySelectInstance) categorySelectInstance.destroy();
        select.innerHTML = `<option value="">Chọn danh mục</option>${categories
          .map((item) => `<option value="${item.name}">${item.name}</option>`)
          .join("")}`;
        categorySelectInstance = new TomSelect("#productCategory", {
          create: false,
          sortField: { field: "text", direction: "asc" },
          placeholder: "Tìm kiếm danh mục...",
        });
      };

      const populateCategoryFilter = (categories) => {
        categorySelect.innerHTML = `<option value="">Tất cả danh mục</option>${categories
          .map((cat) => `<option value="${cat.name}">${cat.name}</option>`)
          .join("")}`;
      };

      const loadCategoriesAndBrands = async () => {
        const [categoriesResult, brandsResult] = await Promise.all([
          getAdminCategories(),
          getAdminBrands(),
        ]);
        const categories = categoriesResult.success ? categoriesResult.categories : [];
        const brands = brandsResult.success ? brandsResult.brands : [];
        populateBrandSelect(brands);
        populateCategorySelect(categories);
        populateCategoryFilter(categories);
      };

      const attachCategoryRowListeners = () => {
        document.querySelectorAll(".edit-category-btn").forEach((btn) => {
          btn.addEventListener("click", () => {
            categoryIdInput.value = btn.dataset.id;
            categoryNameInput.value = btn.dataset.name;
            categoryModalTitle.textContent = "Chỉnh sửa danh mục";
            categoryModal.classList.remove("hidden");
          });
        });
        document.querySelectorAll(".delete-category-btn").forEach((btn) => {
          btn.addEventListener("click", async () => {
            if (confirm(`Xóa danh mục "${btn.dataset.name}"?`)) {
              const result = await deleteCategory(btn.dataset.id);
              if (result.success) {
                alert(result.message);
                loadCategoriesAndBrands();
              } else {
                alert(result.message || "Không thể xóa danh mục");
              }
            }
          });
        });
      };

      const attachBrandRowListeners = () => {
        document.querySelectorAll(".edit-brand-btn").forEach((btn) => {
          btn.addEventListener("click", () => {
            brandIdInput.value = btn.dataset.id;
            brandNameInput.value = btn.dataset.name;
            brandModalTitle.textContent = "Chỉnh sửa thương hiệu";
            brandModal.classList.remove("hidden");
          });
        });
        document.querySelectorAll(".delete-brand-btn").forEach((btn) => {
          btn.addEventListener("click", async () => {
            if (confirm(`Xóa thương hiệu "${btn.dataset.name}"?`)) {
              const result = await deleteBrand(btn.dataset.id);
              if (result.success) {
                alert(result.message);
                loadCategoriesAndBrands();
              } else {
                alert(result.message || "Không thể xóa thương hiệu");
              }
            }
          });
        });
      };

      const openCategoryModal = () => {
        categoryIdInput.value = "";
        categoryNameInput.value = "";
        categoryModalTitle.textContent = "Thêm danh mục";
        categoryModal.classList.remove("hidden");
      };

      const openBrandModal = () => {
        brandIdInput.value = "";
        brandNameInput.value = "";
        brandModalTitle.textContent = "Thêm thương hiệu";
        brandModal.classList.remove("hidden");
      };

      const closeCategoryModal = () => {
        categoryModal.classList.add("hidden");
        categoryForm.reset();
      };

      const closeBrandModal = () => {
        brandModal.classList.add("hidden");
        brandForm.reset();
      };

      categoryForm.addEventListener("submit", async (event) => {
        event.preventDefault();
        const payload = { name: categoryNameInput.value.trim() };
        let result;
        if (categoryIdInput.value) {
          result = await updateCategory(categoryIdInput.value, payload);
        } else {
          result = await createCategory(payload);
        }
        if (result.success) {
          alert(result.message);
          closeCategoryModal();
          loadCategoriesAndBrands();
        } else {
          alert(result.message || "Lỗi khi lưu danh mục");
        }
      });

      brandForm.addEventListener("submit", async (event) => {
        event.preventDefault();
        const payload = { name: brandNameInput.value.trim() };
        let result;
        if (brandIdInput.value) {
          result = await updateBrand(brandIdInput.value, payload);
        } else {
          result = await createBrand(payload);
        }
        if (result.success) {
          alert(result.message);
          closeBrandModal();
          loadCategoriesAndBrands();
        } else {
          alert(result.message || "Lỗi khi lưu thương hiệu");
        }
      });

      document.getElementById("closeCategoryModalBtn")?.addEventListener("click", closeCategoryModal);
      document.getElementById("cancelCategoryBtn")?.addEventListener("click", closeCategoryModal);
      document.getElementById("closeBrandModalBtn")?.addEventListener("click", closeBrandModal);
      document.getElementById("cancelBrandBtn")?.addEventListener("click", closeBrandModal);

      document.addEventListener("click", (event) => {
        if (event.target === categoryModal) closeCategoryModal();
        if (event.target === brandModal) closeBrandModal();
      });

      // Open add/edit modal
      function openAddModal() {
        editingProductId = null;
        modalTitle.textContent = "Thêm Sản Phẩm";
        submitBtn.textContent = "Thêm Sản Phẩm";
        productForm.reset();
        
        const imgFileText = document.getElementById("currentImageText");
        if (imgFileText) imgFileText.classList.add("hidden");
        
        productModal.classList.remove("hidden");
      }

      function openEditModal(product) {
        editingProductId = product._id;
        modalTitle.textContent = "Chỉnh Sửa Sản Phẩm";
        submitBtn.textContent = "Cập Nhật";

        document.getElementById("productId").value = product._id;
        document.getElementById("productName").value = product.name;

        if (brandSelectInstance) {
          brandSelectInstance.setValue(product.brand || "");
        } else {
          document.getElementById("productBrand").value = product.brand || "";
        }

        if (categorySelectInstance) {
          categorySelectInstance.setValue(product.category || "");
        } else {
          document.getElementById("productCategory").value = product.category || "";
        }

        document.getElementById("productPrice").value = product.price;
        document.getElementById("productQuantity").value = product.quantity;
        document.getElementById("productWeight").value = product.weight || "";
        document.getElementById("productLifeStage").value = product.lifeStage || "";
        document.getElementById("productFlavor").value = product.flavor || "";
        document.getElementById("productOrigin").value = product.origin || "";
        document.getElementById("productBenefits").value = (product.benefits || []).join(", ");
        document.getElementById("productIngredients").value = (product.ingredients || []).join(", ");
        document.getElementById("productDescription").value = product.description || "";
        document.getElementById("productDetailedDescription").value = product.detailedDescription || "";
        
        const imgInput = document.getElementById("productImage");
        const imgFileText = document.getElementById("currentImageText");
        
        if (product.image && product.image.includes("uploads/")) {
          imgInput.value = ""; 
          if (imgFileText) {
             const fileName = product.image.split('/').pop();
             imgFileText.textContent = `Ảnh hiện tại: ${fileName}`;
             imgFileText.classList.remove("hidden");
          }
        } else {
          imgInput.value = product.image || "";
          if (imgFileText) {
             imgFileText.classList.add("hidden");
          }
        }
        
        document.getElementById("productImageFile").value = ""; // Reset file input

        productModal.classList.remove("hidden");
      }

      function closeModal() {
        productModal.classList.add("hidden");
        editingProductId = null;
        productForm.reset();
      }

      // Handle form submission
      productForm.addEventListener("submit", async (e) => {
        e.preventDefault();

        const formData = new FormData();
        formData.append("name", document.getElementById("productName").value);
        formData.append("category", document.getElementById("productCategory").value);
        formData.append("brand", document.getElementById("productBrand").value);
        formData.append("price", document.getElementById("productPrice").value);
        formData.append("quantity", document.getElementById("productQuantity").value);
        formData.append("weight", document.getElementById("productWeight").value);
        formData.append("lifeStage", document.getElementById("productLifeStage").value);
        formData.append("flavor", document.getElementById("productFlavor").value);
        formData.append("origin", document.getElementById("productOrigin").value);
        formData.append("benefits", document.getElementById("productBenefits").value);
        formData.append("ingredients", document.getElementById("productIngredients").value);
        formData.append("description", document.getElementById("productDescription").value);
        formData.append("detailedDescription", document.getElementById("productDetailedDescription").value);
        
        const imageUrl = document.getElementById("productImage").value;
        if (imageUrl) formData.append("image", imageUrl);
        
        const imageFile = document.getElementById("productImageFile").files[0];
        if (imageFile) formData.append("imageFile", imageFile);

        let result;
        if (editingProductId) {
          result = await updateProduct(editingProductId, formData);
        } else {
          result = await createProduct(formData);
        }

        if (result.success) {
          alert(
            result.message ||
              (editingProductId
                ? "Cập nhật sản phẩm thành công"
                : "Thêm sản phẩm thành công"),
          );
          closeModal();
          loadProducts();
        } else {
          // Show validation errors from controller
          if (result.errors && Array.isArray(result.errors)) {
            const errorMessage = result.errors.join("\n• ");
            alert("Lỗi xác thực:\n• " + errorMessage);
          } else {
            alert(result.message || "Lỗi khi lưu sản phẩm");
          }
        }
      });

      // Event listeners
      addProductBtn.addEventListener("click", openAddModal);
      closeModalBtn.addEventListener("click", closeModal);
      cancelBtn.addEventListener("click", closeModal);

      // Pagination handlers
      prevPageBtn?.addEventListener("click", () => goToPage(currentPage - 1));
      nextPageBtn?.addEventListener("click", () => goToPage(currentPage + 1));

      // Close modal when clicking outside
      productModal.addEventListener("click", (e) => {
        if (e.target === productModal) {
          closeModal();
        }
      });

      // Search functionality
      searchInput?.addEventListener("keyup", () => {
        currentFilters.search = searchInput.value;
        currentPage = 1;
        loadProducts();
      });

      // Category filter
      categorySelect?.addEventListener("change", (e) => {
        if (e.target.value) {
          currentFilters.category = e.target.value;
        } else {
          delete currentFilters.category;
        }
        currentPage = 1;
        loadProducts();
      });

      // Admin info
      const userInfo = getUserInfo();
      if (userInfo) {
        const nameEl = document.getElementById("adminDisplayName");
        const avatarEl = document.getElementById("adminAvatarSidebar");
        if (nameEl) nameEl.textContent = userInfo.fullName || userInfo.email;
        if (avatarEl)
          avatarEl.textContent = (userInfo.fullName || userInfo.email || "A")
            .charAt(0)
            .toUpperCase();
      }

      // Logout handler
      const logoutBtn = document.getElementById("logoutBtn");
      if (logoutBtn) {
        logoutBtn.addEventListener("click", async (e) => {
          e.preventDefault();
          if (confirm("Bạn có chắc chắn muốn đăng xuất?")) {
            await logoutUser();
            window.location.href = "/auth/login";
          }
        });
      }

      // Initial load
      loadProducts();
      loadCategoriesAndBrands();
    </script>
    <script src="/js/animations.js"></script>
  </body>
</html>
