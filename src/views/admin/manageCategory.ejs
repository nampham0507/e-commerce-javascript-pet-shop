              ],
            },
          },
        },
      };
    </script>
    <style>
      body {
        background-color: #fff8f4;
        color: #211a13;
      }
      .material-symbols-outlined {
        font-variation-settings:
          "FILL" 0,
          "wght" 400,
          "GRAD" 0,
          "opsz" 24;
      }
      .soft-shadow {
        box-shadow: 0 10px 30px -10px rgba(132, 84, 0, 0.08);
      }
      .table-row-hover:hover {
        background-color: #f9ecdf;
      }
    </style>
  </head>
  <body class="font-body-md text-body-md">
    <%- include('../partials/admin-sidebar', { activePage: 'categories' }) %>
    <main class="ml-64 p-xl min-h-screen">
      <header
        class="flex flex-col md:flex-row justify-between items-start md:items-center mb-xl gap-md"
      >
        <div>
          <h2
            class="font-headline-lg text-headline-lg text-on-surface section-heading"
          >
            Quản Lý Danh Mục
          </h2>
        </div>
        <button
          id="addCategoryBtn"
          class="bg-primary-container text-on-primary-container font-label-md text-label-md px-lg py-3 rounded-full flex items-center gap-2 hover:scale-105 transition-transform shadow-md active:scale-95 btn-ripple"
        >
          <span class="material-symbols-outlined">add</span>
          Thêm Danh Mục
        </button>
      </header>

      <div
        class="bg-white rounded-[24px] p-md mb-lg border border-outline-variant soft-shadow flex flex-wrap items-center gap-md reveal delay-1"
      >
        <div class="flex-1 min-w-[300px] relative">
          <span
            class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline"
            >search</span
          >
          <input
            id="searchCategoryInput"
            class="w-full bg-surface-container-low border-none rounded-full py-3 pl-12 pr-4 focus:ring-2 focus:ring-primary-container font-body-md text-body-md"
            placeholder="Tìm kiếm danh mục theo tên..."
            type="text"
          />
        </div>
      </div>

      <div
        id="categoriesTableSection"
        class="bg-white rounded-[24px] border border-outline-variant soft-shadow overflow-hidden reveal"
      >
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead class="bg-surface-container-low">
              <tr>
                <th
                  class="px-lg py-md font-label-md text-label-md text-on-surface-variant uppercase tracking-wider"
                >
                  Danh mục
                </th>
                <th
                  class="px-lg py-md font-label-md text-label-md text-on-surface-variant uppercase tracking-wider"
                >
                  Slug
                </th>
                <th
                  class="px-lg py-md font-label-md text-label-md text-on-surface-variant uppercase tracking-wider text-right"
                >
                  Thao tác
                </th>
              </tr>
            </thead>
            <tbody id="categoriesTableBody" class="divide-y divide-outline-variant">
              <tr>
                <td
                  colspan="3"
                  class="px-lg py-xl text-center text-on-surface-variant"
                >
                  Đang tải danh mục...
                </td>
              </tr>
            </tbody>
          </table>
        </div>
        <div
          class="px-lg py-md bg-surface-container-low flex flex-col sm:flex-row sm:items-center sm:justify-between gap-sm"
        >
          <span
            id="categoryPaginationSummary"
            class="text-label-sm text-on-surface-variant whitespace-nowrap"
          ></span>
          <div
            id="paginationControls"
            class="flex items-center sm:justify-end"
          ></div>
        </div>
      </div>

    <%- include('../partials/footer') %>
    </main>

    <div
      id="categoryModal"
      class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-lg"
    >
      <div
        class="bg-white rounded-[32px] w-full max-w-md shadow-xl overflow-hidden"
      >
        <div
          class="sticky top-0 bg-white px-xl py-lg border-b border-outline-variant flex items-center justify-between"
        >
          <h3
            id="categoryModalTitle"
            class="font-headline-lg text-headline-lg text-on-surface"
          >
            Thêm danh mục
          </h3>
          <button
            id="closeCategoryModalBtn"
            class="p-2 text-on-surface-variant hover:text-on-surface transition-colors"
          >
            <span class="material-symbols-outlined">close</span>
          </button>
        </div>
        <form id="categoryForm" class="p-xl space-y-lg">
          <input type="hidden" id="categoryId" />
          <div>
            <label
              class="block font-label-md text-label-md text-on-surface mb-sm"
              >Tên danh mục</label
            >
            <input
              id="categoryName"
              type="text"
              class="w-full bg-surface-container-low border-none rounded-full px-lg py-md focus:ring-2 focus:ring-primary-container outline-none text-body-md"
              placeholder="Nhập tên danh mục"
              required
            />
          </div>
          <div>
            <label
              class="block font-label-md text-label-md text-on-surface mb-sm"
              >Mô tả (tuỳ chọn)</label
            >
            <input
              id="categoryDescription"
              type="text"
              class="w-full bg-surface-container-low border-none rounded-full px-lg py-md focus:ring-2 focus:ring-primary-container outline-none text-body-md"
              placeholder="Mô tả ngắn về danh mục"
            />
          </div>
          <div class="flex gap-md pt-lg">
            <button
              type="submit"
              class="flex-1 bg-primary text-on-primary font-label-md px-lg py-md rounded-full hover:scale-105 transition-transform shadow-md active:scale-95 btn-ripple text-body-md"
            >
              Lưu
            </button>
            <button
              type="button"
              id="cancelCategoryBtn"
              class="flex-1 bg-surface-container-high text-on-surface font-label-md px-lg py-md rounded-full hover:bg-surface-container-highest transition-colors text-body-md"
            >
              Hủy
            </button>
          </div>
        </form>
      </div>
    </div>

    <script type="module">
      import { logoutUser, getUserInfo, isAuthenticated } from "/js/auth.js";
      import {
        getAdminCategories,
        createCategory,
        updateCategory,
        deleteCategory,
      } from "/js/admin.js";
      import {
        renderPagination as renderPaginationControl,
        renderPaginationSummary,
        scrollToTableTop,
      } from "/js/pagination.js";

      if (!isAuthenticated() || getUserInfo()?.role !== "admin") {
        window.location.href = "/auth/login";
      }

      const categoriesTableBody = document.getElementById("categoriesTableBody");
      const addCategoryBtn = document.getElementById("addCategoryBtn");
      const categoryModal = document.getElementById("categoryModal");
      const closeCategoryModalBtn = document.getElementById("closeCategoryModalBtn");
      const cancelCategoryBtn = document.getElementById("cancelCategoryBtn");
      const categoryForm = document.getElementById("categoryForm");
      const categoryModalTitle = document.getElementById("categoryModalTitle");
      const categoryNameInput = document.getElementById("categoryName");
      const categoryDescriptionInput = document.getElementById("categoryDescription");
      const categoryIdInput = document.getElementById("categoryId");

      const renderCategoryRow = (category) => `
        <tr class="table-row-hover transition-colors">
          <td class="px-lg py-md text-body-md text-on-surface font-medium">${category.name}</td>
          <td class="px-lg py-md text-label-sm text-on-surface-variant">${category.slug || ""}</td>
          <td class="px-lg py-md text-right">
            <div class="flex justify-end gap-2">
              <button data-id="${category._id}" data-name="${category.name}" data-desc="${category.description || ""}" class="p-2 text-on-surface-variant hover:text-primary transition-colors hover:bg-primary-container/10 rounded-full edit-category-btn">
                <span class="material-symbols-outlined">edit</span>
              </button>
              <button data-id="${category._id}" data-name="${category.name}" class="p-2 text-on-surface-variant hover:text-error transition-colors hover:bg-error-container/20 rounded-full delete-category-btn">
                <span class="material-symbols-outlined">delete</span>
              </button>
            </div>
          </td>
        </tr>
      `;

      let allCategories = [];
      let filteredCategories = [];
      let currentCategoryPage = 1;
      const categoriesPerPage = 10;

      const renderCategories = () => {
        const totalPages =
          Math.ceil(filteredCategories.length / categoriesPerPage) || 1;
        if (currentCategoryPage > totalPages) currentCategoryPage = totalPages;
        if (currentCategoryPage < 1) currentCategoryPage = 1;

        const start = (currentCategoryPage - 1) * categoriesPerPage;
        const end = start + categoriesPerPage;
        const paginated = filteredCategories.slice(start, end);

        if (paginated.length > 0) {
          categoriesTableBody.innerHTML = paginated.map(renderCategoryRow).join("");
          attachCategoryListeners();
        } else {
          categoriesTableBody.innerHTML = `
            <tr>
              <td colspan="3" class="px-lg py-xl text-center text-on-surface-variant">Không tìm thấy danh mục nào</td>
            </tr>
          `;
        }

        renderPaginationSummary(
          document.getElementById("categoryPaginationSummary"),
          {
            page: currentCategoryPage,
            limit: categoriesPerPage,
            total: filteredCategories.length,
            itemLabel: "danh mục",
          }
        );

        renderPaginationControl(document.getElementById("paginationControls"), {
          page: currentCategoryPage,
          pages: totalPages,
          onChange: (targetPage) => {
            currentCategoryPage = targetPage;
            renderCategories();
            scrollToTableTop(document.getElementById("categoriesTableSection"));
          },
        });
      };

      const searchCategoryInput = document.getElementById("searchCategoryInput");

      const applySearch = () => {
        const searchTerm = searchCategoryInput
          ? searchCategoryInput.value.toLowerCase().trim()
          : "";
        filteredCategories = searchTerm
          ? allCategories.filter((c) => c.name.toLowerCase().includes(searchTerm))
          : [...allCategories];
        currentCategoryPage = 1;
        renderCategories();
      };

      searchCategoryInput?.addEventListener("input", applySearch);

      const loadCategories = async () => {
        const response = await getAdminCategories();
        if (response.success) {
          allCategories = response.categories || [];
          applySearch();
        } else {
          categoriesTableBody.innerHTML = `
            <tr>
              <td colspan="3" class="px-lg py-xl text-center text-error">${response.message || "Lỗi tải danh mục"}</td>
            </tr>
          `;
        }
      };

      const attachCategoryListeners = () => {
        document.querySelectorAll(".edit-category-btn").forEach((btn) => {
          btn.addEventListener("click", () => {
            categoryIdInput.value = btn.dataset.id;
            categoryNameInput.value = btn.dataset.name;
            categoryDescriptionInput.value = btn.dataset.desc || "";
            categoryModalTitle.textContent = "Chỉnh sửa danh mục";
            categoryModal.classList.remove("hidden");
          });
        });
        document.querySelectorAll(".delete-category-btn").forEach((btn) => {
          btn.addEventListener("click", async () => {
            if (confirm(`Xóa danh mục "${btn.dataset.name}"?`)) {
              const result = await deleteCategory(btn.dataset.id);
              if (result.success) {
                alert(result.message);
                await loadCategories();
              } else {
                alert(result.message || "Không thể xóa danh mục");
              }
            }
          });
        });
      };

      const closeModal = () => {
        categoryModal.classList.add("hidden");
        categoryForm.reset();
      };

      addCategoryBtn.addEventListener("click", () => {
        categoryIdInput.value = "";
        categoryNameInput.value = "";
        categoryDescriptionInput.value = "";
        categoryModalTitle.textContent = "Thêm danh mục";
        categoryModal.classList.remove("hidden");
      });
      closeCategoryModalBtn.addEventListener("click", closeModal);
      cancelCategoryBtn.addEventListener("click", closeModal);
      categoryModal.addEventListener("click", (event) => {
        if (event.target === categoryModal) closeModal();
      });

      categoryForm.addEventListener("submit", async (event) => {
        event.preventDefault();
        const payload = {
          name: categoryNameInput.value.trim(),
          description: categoryDescriptionInput.value.trim(),
        };
        let result;
        if (categoryIdInput.value) {
          result = await updateCategory(categoryIdInput.value, payload);
        } else {
          result = await createCategory(payload);
        }
        if (result.success) {
          alert(result.message);
          closeModal();
          await loadCategories();
        } else {
          alert(result.message || "Lỗi khi lưu danh mục");
        }
      });

      const userInfo = getUserInfo();
      if (userInfo) {
        const nameEl = document.getElementById("adminDisplayName");
        const avatarEl = document.getElementById("adminAvatarSidebar");
        if (nameEl) nameEl.textContent = userInfo.fullName || userInfo.email;
        if (avatarEl)
          avatarEl.textContent = (userInfo.fullName || userInfo.email || "A")
            .charAt(0)
            .toUpperCase();
      }

      const logoutBtn = document.getElementById("logoutBtn");
      if (logoutBtn) {
        logoutBtn.addEventListener("click", async (e) => {
          e.preventDefault();
          if (confirm("Bạn có chắc chắn muốn đăng xuất?")) {
            await logoutUser();
            window.location.href = "/auth/login";
          }
        });
      }

      loadCategories();
    </script>
    <script src="/js/animations.js"></script>
  </body>
</html>
