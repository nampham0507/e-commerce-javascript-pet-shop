  <body class="font-body-md text-body-md">
    <%- include('../partials/admin-sidebar', { activePage: 'reviews' }) %>
    <main class="ml-64 p-xl min-h-screen">
      <header
        class="flex flex-col md:flex-row justify-between items-start md:items-center mb-xl gap-md"
      >
        <div>
          <h2
            class="font-headline-lg text-headline-lg text-on-surface section-heading"
          >
            Quản Lý Đánh Giá
          </h2>
          <p class="text-on-surface-variant text-body-md mt-1">
            Xem đánh giá của khách hàng và phản hồi với vai trò Quản trị viên
          </p>
        </div>
      </header>

      <div
        class="bg-white rounded-[24px] p-md mb-lg border border-outline-variant soft-shadow flex flex-wrap items-center gap-md reveal delay-1"
      >
        <div class="flex items-center gap-sm">
          <label
            for="ratingFilter"
            class="font-label-md text-label-md text-on-surface-variant"
            >Số sao</label
          >
          <select
            id="ratingFilter"
            class="bg-surface-container-low border-none rounded-full px-lg py-2 focus:ring-2 focus:ring-primary-container font-body-md text-body-md"
          >
            <option value="">Tất cả</option>
            <option value="5">5 sao</option>
            <option value="4">4 sao</option>
            <option value="3">3 sao</option>
            <option value="2">2 sao</option>
            <option value="1">1 sao</option>
          </select>
        </div>
      </div>

      <div id="adminReviewList" class="space-y-lg reveal">
        <div class="text-on-surface-variant text-center py-xl">
          Đang tải đánh giá...
        </div>
      </div>

      <div
        class="px-lg py-md mt-lg bg-white rounded-[24px] border border-outline-variant soft-shadow flex justify-end items-center gap-2"
        id="paginationControls"
      ></div>

    <%- include('../partials/footer') %>
    </main>

    <script type="module">
      import { logoutUser, getUserInfo, isAuthenticated } from "/js/auth.js";
      import { initAdminReviews } from "/js/adminReviews.js";

      if (!isAuthenticated() || getUserInfo()?.role !== "admin") {
        window.location.href = "/auth/login";
      }

      const userInfo = getUserInfo();
      if (userInfo) {
        const nameEl = document.getElementById("adminDisplayName");
        const avatarEl = document.getElementById("adminAvatarSidebar");
        if (nameEl) nameEl.textContent = userInfo.fullName || userInfo.email;
        if (avatarEl)
          avatarEl.textContent = (userInfo.fullName || userInfo.email || "A")
            .charAt(0)
            .toUpperCase();
      }

      const logoutBtn = document.getElementById("logoutBtn");
      if (logoutBtn) {
        logoutBtn.addEventListener("click", async (e) => {
          e.preventDefault();
          if (confirm("Bạn có chắc chắn muốn đăng xuất?")) {
            await logoutUser();
            window.location.href = "/auth/login";
          }
        });
      }

      initAdminReviews({ notify: (msg) => alert(msg) });
    </script>
    <script src="/js/animations.js"></script>
  </body>
</html>
