    <style>
      body {
        background-color: #fff8f4;
        color: #211a13;
      }
      .material-symbols-outlined {
        font-variation-settings:
          "FILL" 0,
          "wght" 400,
          "GRAD" 0,
          "opsz" 24;
      }
      .soft-shadow {
        box-shadow: 0 10px 30px -10px rgba(132, 84, 0, 0.08);
      }
    </style>
