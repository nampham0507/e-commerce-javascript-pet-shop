    </main>
    <!-- Footer -->
    <%- include('../partials/footer') %>
    <script type="module">
      import { isAuthenticated, getUserInfo, logoutUser } from "/js/auth.js";
      import { addToCart, getCartItemCount, syncCartFromBackend } from "/js/cart.js?v=1780539375686";
      import { initReviewSection } from "/js/reviews.js";

      const guestNav = document.getElementById("guestNav");
      const userNav = document.getElementById("userNav");
      const userAvatar = document.getElementById("userAvatar");
      const userName = document.getElementById("userName");
      const menuUserName = document.getElementById("menuUserName");
      const menuUserEmail = document.getElementById("menuUserEmail");
      const adminLink = document.getElementById("adminLink");
      const menuAdminLink = document.getElementById("menuAdminLink");
      const userMenu = document.getElementById("userMenu");
      const chevronIcon = document.getElementById("chevronIcon");
      const logoutBtn = document.getElementById("logoutBtn");
      const userAvatarBtn = document.getElementById("userAvatarBtn");
      const addToCartBtn = document.getElementById("addToCartBtn");
      const quantityValue = document.getElementById("quantityValue");
      const qtyDecreaseBtn = document.getElementById("qtyDecreaseBtn");
      const qtyIncreaseBtn = document.getElementById("qtyIncreaseBtn");
      const mobileGuestNav = document.getElementById("mobileGuestNav");

      function initNav() {
        if (isAuthenticated()) {
          const user = getUserInfo();
          if (!user) return;

          // Hiển thị khu vực user, ẩn guest
          guestNav.style.display = "none";
          userNav.style.display = "flex";

          // Đặt chữ cái đầu tên vào avatar
          const initial = (user.fullName || user.email || "U")
            .charAt(0)
            .toUpperCase();
          userAvatar.textContent = initial;

          // Đặt tên hiển thị
          const displayName = user.fullName || user.email;
          userName.textContent = displayName;
          menuUserName.textContent = displayName;
          menuUserEmail.textContent = user.email || "";

          // Hiện link Admin nếu là admin
          if (user.role === "admin") {
            adminLink.style.display = "flex";
            menuAdminLink.style.display = "flex";
          }
          mobileGuestNav.classList.add("hidden");
          mobileGuestNav.classList.remove("flex");
        } else {
          guestNav.style.display = "";
          userNav.style.display = "none";
          mobileGuestNav.classList.remove("hidden");
          mobileGuestNav.classList.add("flex");
        }
      }

      function showToast(message) {
        const toast = document.createElement("div");
        toast.className =
          "fixed bottom-5 right-5 z-[60] rounded-full bg-on-surface text-background px-lg py-3 shadow-lg text-label-md";
        toast.textContent = message;
        document.body.appendChild(toast);

        setTimeout(() => {
          toast.remove();
        }, 2200);
      }

      function updateCartBadge() {
        const badge = document.getElementById("cartBadge");
        if (!badge) return;

        const count = getCartItemCount();
        if (count > 0) {
          badge.textContent = count;
          badge.classList.remove("hidden");
        } else {
          badge.classList.add("hidden");
        }
      }

      // Toggle dropdown
      userAvatarBtn.addEventListener("click", (e) => {
        e.stopPropagation();
        const isOpen = userMenu.classList.toggle("open");
        chevronIcon.textContent = isOpen ? "expand_less" : "expand_more";
      });

      // Đóng dropdown khi click ra ngoài
      document.addEventListener("click", () => {
        userMenu.classList.remove("open");
        chevronIcon.textContent = "expand_more";
      });

      // Đăng xuất
      logoutBtn.addEventListener("click", async () => {
        await logoutUser();
        window.location.href = "/auth/login";
      });

      let currentProduct = null;
      let currentQuantity = 1;
      let availableQuantity = 1;

      function updateQuantityControls() {
        if (!quantityValue) return;

        currentQuantity = Math.max(
          1,
          Math.min(currentQuantity, availableQuantity || 1)
        );
        quantityValue.textContent = currentQuantity;

        if (qtyDecreaseBtn) {
          qtyDecreaseBtn.disabled = currentQuantity <= 1;
          qtyDecreaseBtn.classList.toggle("opacity-40", currentQuantity <= 1);
        }

        if (qtyIncreaseBtn) {
          qtyIncreaseBtn.disabled = currentQuantity >= availableQuantity;
          qtyIncreaseBtn.classList.toggle(
            "opacity-40",
            currentQuantity >= availableQuantity
          );
        }
      }

      // Load product details
      async function loadProductDetail() {
        const urlParams = new URLSearchParams(window.location.search);
        const productId = urlParams.get("id");
        if (!productId) {
          document.getElementById("detailName").textContent =
            "Không tìm thấy sản phẩm";
          return;
        }

        try {
          const response = await fetch(`/api/products/${productId}`);
          if (!response.ok) throw new Error("Lỗi khi tải sản phẩm");
          const product = await response.json();
          currentProduct = product;
          availableQuantity = Number(product.quantity || 0);
          currentQuantity = Math.min(
            currentQuantity,
            Math.max(1, availableQuantity || 1)
          );

          // Populate DOM
          document.title = `${product.name} | Xám Pet Shop`;
          document.getElementById("detailImageMain").src =
            product.image || "https://via.placeholder.com/500?text=No+Image";
          document.getElementById("detailCategory").textContent =
            product.category || "General";
          document.getElementById("detailName").textContent = product.name;
          document.getElementById("detailBrand").textContent =
            product.brand || "Chưa cập nhật";

          document.getElementById("detailPrice").textContent =
            new Intl.NumberFormat("vi-VN").format(product.price);
          document.getElementById("detailShortDesc").textContent =
            product.description || "Chưa có mô tả ngắn.";
          document.getElementById("detailQuantity").textContent =
            product.quantity + " sản phẩm có sẵn";
          document.getElementById("detailLongDesc").textContent =
            product.detailedDescription || "Chưa có mô tả chi tiết.";
          updateQuantityControls();

          document.getElementById("detailWeight").textContent =
            product.weight || "N/A";
          document.getElementById("detailLifeStage").textContent =
            product.lifeStage || "N/A";
          document.getElementById("detailFlavor").textContent =
            product.flavor || "N/A";
          document.getElementById("detailOrigin").textContent =
            product.origin || "N/A";

          // Populate benefits
          const benefitsContainer = document.getElementById(
            "detailBenefitsContainer"
          );
          const extraBenefitsContainer = document.getElementById(
            "detailExtraBenefits"
          );
          benefitsContainer.innerHTML = "";
          extraBenefitsContainer.innerHTML = "";

          if (product.benefits && product.benefits.length > 0) {
            product.benefits.forEach((benefit, index) => {
              if (index === 0) {
                benefitsContainer.innerHTML = `<span class="bg-tertiary-fixed text-on-tertiary-fixed-variant px-md py-1 rounded-full text-label-sm">${benefit}</span>`;
              } else {
                extraBenefitsContainer.innerHTML += `
                  <div class="flex items-center gap-1 px-3 py-2 bg-surface-container-high rounded-lg text-label-sm text-on-surface-variant">
                    <span class="material-symbols-outlined text-[18px]">verified</span> ${benefit}
                  </div>
                `;
              }
            });
          }

          // Populate ingredients
          const ingredientsList = document.getElementById(
            "detailIngredientsList"
          );
          ingredientsList.innerHTML = "";
          if (product.ingredients && product.ingredients.length > 0) {
            product.ingredients.forEach((ingredient) => {
              ingredientsList.innerHTML += `
                <li class="flex items-start gap-md">
                  <span class="material-symbols-outlined text-primary mt-1">check_circle</span>
                  <span class="text-body-md text-on-surface-variant">${ingredient}</span>
                </li>
              `;
            });
          }
          
          // Khởi tạo phần đánh giá
          initReviewSection(product._id, { notify: showToast });
        } catch (error) {
          console.error(error);
          document.getElementById("detailName").textContent =
            "Sản phẩm không tồn tại hoặc đã bị xóa.";
        }
      }

      qtyDecreaseBtn?.addEventListener("click", () => {
        currentQuantity = Math.max(1, currentQuantity - 1);
        updateQuantityControls();
      });

      qtyIncreaseBtn?.addEventListener("click", () => {
        currentQuantity = Math.min(availableQuantity || 1, currentQuantity + 1);
        updateQuantityControls();
      });

      addToCartBtn?.addEventListener("click", async () => {
        if (!currentProduct) {
          showToast("Không thể thêm sản phẩm vào giỏ hàng");
          return;
        }

        const result = await addToCart(currentProduct, currentQuantity);
        if (result) {
          updateCartBadge();
          showToast(`Đã thêm ${currentQuantity} sản phẩm vào giỏ hàng`);
        }
      });

      const placeOrderNowBtn = document.getElementById("placeOrderNowBtn");
      placeOrderNowBtn?.addEventListener("click", async () => {
        if (!currentProduct) {
          showToast("Không thể đặt hàng");
          return;
        }

        if (!isAuthenticated()) {
          window.location.href = "/auth/login";
          return;
        }

        // Add to cart then redirect to checkout
        const result = await addToCart(currentProduct, currentQuantity);
        if (result) {
          updateCartBadge();
          window.location.href = "/order/checkout";
        }
      });

      async function initPage() {
        initNav();
        if (isAuthenticated()) {
          await syncCartFromBackend();
        }
        updateCartBadge();
        loadProductDetail();
      }

      // ── Tab switching ─────────────────────────────────────────────────────────
      function switchTab(tab) {
        const panelDesc = document.getElementById("panelDesc");
        const panelReview = document.getElementById("panelReview");
        const tabDesc = document.getElementById("tabDesc");
        const tabReview = document.getElementById("tabReview");
        if (tab === "desc") {
          panelDesc.classList.remove("hidden");
          panelReview.classList.add("hidden");
          tabDesc.classList.add("active-tab");
          tabDesc.classList.remove("text-outline");
          tabReview.classList.remove("active-tab");
          tabReview.classList.add("text-outline");
        } else {
          panelDesc.classList.add("hidden");
          panelReview.classList.remove("hidden");
          tabReview.classList.add("active-tab");
          tabReview.classList.remove("text-outline");
          tabDesc.classList.remove("active-tab");
          tabDesc.classList.add("text-outline");
        }
      }
      window.switchTab = switchTab;

      initPage();

      // Nav search bar
      const navSearchInput = document.getElementById("navSearchInput");
      const navSearchBtn = document.getElementById("navSearchBtn");
      function doNavSearch() {
        const q = navSearchInput?.value.trim();
        if (q) window.location.href = `/product?q=${encodeURIComponent(q)}`;
      }
      navSearchInput?.addEventListener("keydown", (e) => { if (e.key === "Enter") doNavSearch(); });
      navSearchBtn?.addEventListener("click", doNavSearch);

      // Mobile nav toggle
      const mobileMenuBtn = document.getElementById("mobileMenuBtn");
      const mobileMenuIcon = document.getElementById("mobileMenuIcon");
      const mobileNav = document.getElementById("mobileNav");
      mobileMenuBtn.addEventListener("click", () => {
        const isOpen = mobileNav.classList.toggle("grid-rows-[1fr]");
        mobileNav.classList.toggle("grid-rows-[0fr]", !isOpen);
        mobileMenuIcon.textContent = isOpen ? "close" : "menu";
        mobileMenuBtn.setAttribute("aria-expanded", String(isOpen));
      });
    </script>
    <script src="/js/animations.js"></script>
  </body>
</html>
