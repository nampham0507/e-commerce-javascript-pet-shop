    <style>
      body {
        background-color: #fff8f4;
        color: #211a13;
      }
      .material-symbols-outlined {
        font-variation-settings:
          "FILL" 0,
          "wght" 400,
          "GRAD" 0,
          "opsz" 24;
      }
      .custom-shadow {
        box-shadow: 0 10px 30px -10px rgba(132, 84, 0, 0.08);
      }
      .active-tab {
        border-bottom: 3px solid #845400;
        color: #845400;
      }

      /* User dropdown */
      #userMenu {
        display: none;
      }
      #userMenu.open {
        display: block;
      }

      /* Smooth avatar initial */
      #userAvatar {
        width: 36px;
        height: 36px;
        border-radius: 9999px;
        background: #ffb347;
        color: #704700;
        font-weight: 700;
        font-size: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        border: 2px solid #ffddb6;
        transition: transform 0.15s;
        flex-shrink: 0;
      }
      #userAvatar:hover {
        transform: scale(1.08);
      }
    </style>
