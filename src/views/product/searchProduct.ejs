    </script>
    <style>
      .material-symbols-outlined {
        font-variation-settings:
          "FILL" 0,
          "wght" 400,
          "GRAD" 0,
          "opsz" 24;
      }
      .soft-shadow {
        box-shadow: 0 10px 30px -10px rgba(132, 84, 0, 0.08);
      }
      .card-hover:hover {
        transform: translateY(-4px);
        box-shadow: 0 20px 40px -15px rgba(132, 84, 0, 0.12);
      }
      /* User dropdown */
      #userMenu {
        display: none;
      }
      #userMenu.open {
        display: block;
      }
      #userAvatar {
        width: 36px;
        height: 36px;
        border-radius: 9999px;
        background: #ffb347;
        color: #704700;
        font-weight: 700;
        font-size: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        border: 2px solid #ffddb6;
        transition: transform 0.15s;
        flex-shrink: 0;
      }
      #userAvatar:hover {
        transform: scale(1.08);
      }
    </style>
  </head>
  <body
    class="bg-background text-on-background font-body-md selection:bg-primary-container/30"
  >
    <!-- TopNavBar — KHÔNG có ô tìm kiếm -->
    <%- include('../partials/navbar', { activePage: 'products' }) %>

    <main class="pt-32 pb-xl px-md max-w-container-max mx-auto min-h-screen">
      <!-- Search Hero — có tìm kiếm realtime -->
      <div class="relative overflow-hidden rounded-[32px] mb-xl text-center py-xl">
        <div class="gradient-mesh"></div>
        <h1
          class="relative z-10 font-headline-xl text-headline-xl text-primary mb-md section-heading reveal"
        >
          Tìm kiếm sản phẩm
        </h1>
        <div class="relative z-10 max-w-2xl mx-auto group reveal delay-1">
          <input
            id="heroSearchInput"
            class="w-full bg-surface-container-lowest border-2 border-outline-variant focus:border-primary-container rounded-full px-lg py-4 text-body-lg soft-shadow focus:ring-0 transition-all outline-none"
            type="text"
            placeholder="Nhập tên sản phẩm, thương hiệu..."
            autocomplete="off"
          />
          <button
            id="heroSearchBtn"
            class="btn-shine absolute right-2 top-1/2 -translate-y-1/2 bg-primary-container text-on-primary-container h-12 w-12 rounded-full flex items-center justify-center hover:scale-110 transition-transform"
          >
            <span class="material-symbols-outlined">search</span>
          </button>
        </div>
        <p
          id="searchResultCount"
          class="relative z-10 mt-4 text-on-surface-variant font-label-md"
        >
          Đang tải sản phẩm...
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-[280px_1fr] gap-lg">
        <!-- Filters -->
        <aside class="space-y-xl reveal-left delay-2">
          <!-- Category Filter -->
          <div
            class="bg-surface-container-low rounded-xl p-lg border border-outline-variant/30"
          >
            <h3
              class="font-headline-md text-headline-md text-on-surface mb-md flex items-center gap-2"
            >
              <span class="material-symbols-outlined text-primary">pets</span>
              Danh mục
            </h3>
            <div id="categoryFilters" class="space-y-3">
              <div class="text-on-surface-variant text-sm">
                Đang tải danh mục...
              </div>
            </div>
          </div>
          <!-- Price Filter -->
          <div
            class="bg-surface-container-low rounded-xl p-lg border border-outline-variant/30"
          >
            <h3
              class="font-headline-md text-headline-md text-on-surface mb-md flex items-center gap-2"
            >
              <span class="material-symbols-outlined text-primary"
                >payments</span
              >
              Khoảng giá
            </h3>
            <div class="space-y-4">
              <input
                id="priceRange"
                class="w-full h-2 bg-outline-variant rounded-lg appearance-none cursor-pointer accent-primary"
                max="2000000"
                min="0"
                value="2000000"
                type="range"
              />
              <div
                class="flex justify-between text-label-sm text-on-surface-variant font-bold"
              >
                <span>0đ</span>
                <span id="priceDisplay">2.000.000đ</span>
              </div>
            </div>
          </div>
          <!-- Brand Filter -->
          <div
            class="bg-surface-container-low rounded-xl p-lg border border-outline-variant/30"
          >
            <h3
              class="font-headline-md text-headline-md text-on-surface mb-md flex items-center gap-2"
            >
              <span class="material-symbols-outlined text-primary"
                >verified</span
              >
              Thương hiệu
            </h3>
            <div id="brandFilters" class="space-y-3">
              <label class="flex items-center gap-3 cursor-pointer group">
                <input
                  class="border-outline-variant text-primary focus:ring-primary-container w-5 h-5"
                  name="brand"
                  type="radio"
                  value=""
                  checked
                />
                <span
                  class="text-body-md group-hover:text-primary transition-colors"
                  >Tất cả</span
                >
              </label>
            </div>
          </div>
          <!-- Reset button -->
          <button
            id="resetFiltersBtn"
            class="w-full bg-primary text-on-primary py-3 rounded-full font-label-md hover:scale-105 transition-transform active:scale-95"
          >
            Xóa tất cả bộ lọc
          </button>
        </aside>

        <!-- Search Results -->
        <section class="space-y-lg reveal-right delay-2">
          <!-- Sorting & View -->
          <div
            class="flex justify-between items-center bg-white/50 backdrop-blur-sm p-md rounded-xl border border-outline-variant/20"
          >
            <div class="flex gap-4">
              <button
                class="flex items-center gap-1 text-label-md text-primary font-bold"
              >
                <span class="material-symbols-outlined text-[20px]"
                  >grid_view</span
                >
                Lưới
              </button>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-label-sm text-on-surface-variant"
                >Sắp xếp:</span
              >
              <select
                id="sortSelect"
                class="bg-transparent border-none text-label-md text-on-surface font-bold focus:ring-0 cursor-pointer"
              >
                <option value="default">Mới nhất</option>
                <option value="price_asc">Giá thấp đến cao</option>
                <option value="price_desc">Giá cao đến thấp</option>
              </select>
            </div>
          </div>
          <!-- Product Grid -->
          <div
            id="productsGrid"
            class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-gutter"
            data-stagger
          >
            <div
              class="col-span-full text-center py-xl text-on-surface-variant"
            >
              Đang tải...
            </div>
          </div>
          <!-- Empty State -->
          <div
            id="emptyState"
            class="hidden flex-col items-center justify-center py-24 text-center space-y-6"
          >
            <div
              class="w-48 h-48 bg-surface-container-high rounded-full flex items-center justify-center"
            >
              <span
                class="material-symbols-outlined text-[80px] text-outline-variant"
                >sentiment_dissatisfied</span
              >
            </div>
            <div class="space-y-2">
              <h2 class="font-headline-lg text-headline-lg text-on-surface">
                Rất tiếc, không tìm thấy sản phẩm
              </h2>
              <p class="text-on-surface-variant max-w-sm mx-auto">
                Thử dùng từ khóa khác hoặc xóa bớt bộ lọc nhé!
              </p>
            </div>
          </div>
        </section>
      </div>
    </main>

    <!-- Footer -->
    <%- include('../partials/footer') %>

    <script type="module">
      import { isAuthenticated, getUserInfo, logoutUser } from "/js/auth.js";
      import { getPublicProducts } from "/js/product.js";
      import { addToCart, getCartItemCount } from "/js/cart.js?v=1780539375687";

      // ── Auth Nav ─────────────────────────────────────────────────────────────
      const guestNav = document.getElementById("guestNav");
      const userNav = document.getElementById("userNav");
      const userAvatar = document.getElementById("userAvatar");
      const userName = document.getElementById("userName");
      const menuUserName = document.getElementById("menuUserName");
      const menuUserEmail = document.getElementById("menuUserEmail");
      const adminLink = document.getElementById("adminLink");
      const menuAdminLink = document.getElementById("menuAdminLink");
      const userMenu = document.getElementById("userMenu");
      const chevronIcon = document.getElementById("chevronIcon");
      const logoutBtn = document.getElementById("logoutBtn");
      const userAvatarBtn = document.getElementById("userAvatarBtn");
      const mobileGuestNav = document.getElementById("mobileGuestNav");

      function initNav() {
        if (isAuthenticated()) {
          const user = getUserInfo();
          if (!user) return;
          guestNav.style.display = "none";
          userNav.style.display = "flex";
          const initial = (user.fullName || user.email || "U")
            .charAt(0)
            .toUpperCase();
          userAvatar.textContent = initial;
          const displayName = user.fullName || user.email;
          userName.textContent = displayName;
          menuUserName.textContent = displayName;
          menuUserEmail.textContent = user.email || "";
          if (user.role === "admin") {
            adminLink.style.display = "flex";
            menuAdminLink.style.display = "flex";
          }
          mobileGuestNav.classList.add("hidden");
          mobileGuestNav.classList.remove("flex");
        } else {
          guestNav.style.display = "";
          userNav.style.display = "none";
          mobileGuestNav.classList.remove("hidden");
          mobileGuestNav.classList.add("flex");
        }
      }

      userAvatarBtn.addEventListener("click", (e) => {
        e.stopPropagation();
        const isOpen = userMenu.classList.toggle("open");
        chevronIcon.textContent = isOpen ? "expand_less" : "expand_more";
      });
      document.addEventListener("click", () => {
        userMenu.classList.remove("open");
        chevronIcon.textContent = "expand_more";
      });
      logoutBtn.addEventListener("click", async () => {
        await logoutUser();
        window.location.href = "/auth/login";
      });

      // ── Search & Filter ───────────────────────────────────────────────────────
      const productsGrid = document.getElementById("productsGrid");
      const emptyState = document.getElementById("emptyState");
      const searchResultCount = document.getElementById("searchResultCount");
      const heroSearchInput = document.getElementById("heroSearchInput");
      const heroSearchBtn = document.getElementById("heroSearchBtn");
      const priceRange = document.getElementById("priceRange");
      const priceDisplay = document.getElementById("priceDisplay");
      const sortSelect = document.getElementById("sortSelect");
      const resetFiltersBtn = document.getElementById("resetFiltersBtn");
      const categoryFilters = document.getElementById("categoryFilters");
      const brandFilters = document.getElementById("brandFilters");

      let allProducts = [];
      let currentSearch = "";
      let currentMaxPrice = 2000000;
      let currentBrand = "";
      let currentCategories = [];
      let currentSort = "default";
      let debounceTimer = null;

      const renderCategoryFilters = (categories) => {
        if (!categoryFilters) return;
        if (!categories || categories.length === 0) {
          categoryFilters.innerHTML = '<div class="text-on-surface-variant text-sm">Chưa có danh mục nào</div>';
          return;
        }
        categoryFilters.innerHTML = categories
          .map(
            (category) => `
              <label class="flex items-center gap-3 cursor-pointer group">
                <input
                  class="rounded border-outline-variant text-primary focus:ring-primary-container w-5 h-5 category-filter"
                  type="checkbox"
                  value="${category.name}"
                />
                <span class="text-body-md group-hover:text-primary transition-colors">${category.name}</span>
              </label>
            `
          )
          .join("");
      };

      const renderBrandFilters = (brands) => {
        if (!brandFilters) return;
        brandFilters.innerHTML = `
          <label class="flex items-center gap-3 cursor-pointer group">
            <input
              class="border-outline-variant text-primary focus:ring-primary-container w-5 h-5"
              name="brand"
              type="radio"
              value=""
              checked
            />
            <span class="text-body-md group-hover:text-primary transition-colors">Tất cả</span>
          </label>
          ${brands
            .map(
              (brand) => `
                <label class="flex items-center gap-3 cursor-pointer group">
                  <input
                    class="border-outline-variant text-primary focus:ring-primary-container w-5 h-5"
                    name="brand"
                    type="radio"
                    value="${brand.name}"
                  />
                  <span class="text-body-md group-hover:text-primary transition-colors">${brand.name}</span>
                </label>
              `
            )
            .join("")}
        `;
      };

      const attachFilterListeners = () => {
        document.querySelectorAll(".category-filter").forEach((cb) => {
          cb.addEventListener("change", () => {
            currentCategories = Array.from(
              document.querySelectorAll(".category-filter:checked")
            ).map((c) => c.value);
            applyFilters();
          });
        });

        document.querySelectorAll("[name='brand']").forEach((rb) => {
          rb.addEventListener("change", () => {
            currentBrand = rb.value;
            applyFilters();
          });
        });
      };

      function formatPrice(price) {
        return new Intl.NumberFormat("vi-VN", {
          style: "currency",
          currency: "VND",
          minimumFractionDigits: 0,
        }).format(price);
      }

      function renderProductCard(product) {
        return `
          <div class="tilt-card bg-white rounded-[24px] border border-outline-variant/40 overflow-hidden shadow-sm hover:shadow-2xl transition-all duration-300 group">
            <a href="/product/detail?id=${product._id}" class="img-zoom relative aspect-square p-lg bg-white flex items-center justify-center block">
              <img
                class="w-full h-full object-contain"
                src="${product.image || "https://via.placeholder.com/256?text=No+Image"}"
                alt="${product.name}"
              />
            </a>
            <div class="p-lg space-y-2">
              <div class="flex gap-2 mb-2">
                <span class="bg-surface-container-highest text-primary px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider">${product.category || "Sản phẩm"}</span>
              </div>
              <a href="/product/detail?id=${product._id}" class="hover:underline">
                <h4 class="font-headline-md text-body-lg text-on-surface group-hover:text-primary transition-colors">${product.name}</h4>
              </a>
              <p class="text-on-surface-variant text-label-sm line-clamp-2">${product.description || ""}</p>
              <div class="flex justify-between items-center pt-4">
                <span class="text-primary font-bold text-headline-md">${formatPrice(product.price)}</span>
                <button data-add-id="${product._id}" class="btn-shine bg-primary-container text-on-primary-container p-3 rounded-full hover:scale-110 transition-transform active:scale-95">
                  <span class="material-symbols-outlined">add_shopping_cart</span>
                </button>
              </div>
            </div>
          </div>
        `;
      }

      function applyFilters() {
        let filtered = [...allProducts];
        if (currentSearch) {
          const q = currentSearch.toLowerCase();
          filtered = filtered.filter(
            (p) =>
              p.name.toLowerCase().includes(q) ||
              (p.description && p.description.toLowerCase().includes(q)) ||
              (p.brand && p.brand.toLowerCase().includes(q))
          );
        }
        if (currentCategories.length > 0) {
          filtered = filtered.filter((p) =>
            currentCategories.some(
              (c) => c.toLowerCase() === (p.category || "").toLowerCase()
            )
          );
        }
        filtered = filtered.filter((p) => p.price <= currentMaxPrice);
        if (currentBrand) {
          filtered = filtered.filter((p) =>
            (p.brand || "").toLowerCase().includes(currentBrand.toLowerCase())
          );
        }
        if (currentSort === "price_asc")
          filtered.sort((a, b) => a.price - b.price);
        else if (currentSort === "price_desc")
          filtered.sort((a, b) => b.price - a.price);
        renderProducts(filtered);
      }

      function renderProducts(products) {
        if (products.length === 0) {
          productsGrid.classList.add("hidden");
          emptyState.classList.remove("hidden");
          emptyState.classList.add("flex");
          searchResultCount.textContent = "Không tìm thấy sản phẩm nào";
        } else {
          productsGrid.classList.remove("hidden");
          emptyState.classList.add("hidden");
          emptyState.classList.remove("flex");
          productsGrid.innerHTML = products.map(renderProductCard).join("");

          // Re-trigger animations on dynamic product cards
          if (window.XamAnimations) {
            window.XamAnimations.initStagger();
            window.XamAnimations.initCardHover();
            window.XamAnimations.initScrollReveal();
            window.XamAnimations.initTilt(productsGrid);
          }

          const keyword = currentSearch ? ` cho "${currentSearch}"` : "";
          searchResultCount.textContent = `Hiển thị ${products.length} sản phẩm${keyword}`;
        }
      }

      async function loadProducts() {
        productsGrid.innerHTML =
          '<div class="col-span-full text-center py-xl text-on-surface-variant">Đang tải...</div>';
        const response = await getPublicProducts({ limit: 200 });
        if (response && Array.isArray(response)) {
          allProducts = response;
        } else if (response && response.success) {
          allProducts = response.products || [];
        } else {
          allProducts = [];
        }

        try {
          const categoriesResponse = await fetch("/api/categories");
          const categoriesData = await categoriesResponse.json();
          if (categoriesData.success) {
            renderCategoryFilters(categoriesData.categories || []);
          }
        } catch (err) {
          console.warn("Không thể tải danh mục", err);
        }

        let fetchedBrands = [];
        try {
          const brandsResponse = await fetch("/api/categories/brands");
          const brandsData = await brandsResponse.json();
          if (brandsData.success && Array.isArray(brandsData.brands)) {
            fetchedBrands = brandsData.brands;
          }
        } catch (err) {
          console.warn("Không thể tải thương hiệu", err);
        }

        if (fetchedBrands.length > 0) {
          renderBrandFilters(fetchedBrands);
        } else {
          const brandNames = Array.from(
            new Set(allProducts.map((p) => p.brand).filter(Boolean))
          );
          renderBrandFilters(brandNames.map((name) => ({ name })));
        }
        attachFilterListeners();

        // Đọc query params từ URL
        const urlParams = new URLSearchParams(window.location.search);
        const q = urlParams.get("q") || urlParams.get("search") || "";
        const cat = urlParams.get("category") || "";
        if (q) {
          heroSearchInput.value = q;
          currentSearch = q;
        }
        if (cat) {
          const cb = document.querySelector(`.category-filter[value="${cat}"]`);
          if (cb) {
            cb.checked = true;
            currentCategories = [cat];
          }
        }
        applyFilters();
      }

      // ── Realtime search với debounce 300ms ───────────────────────────────────
      heroSearchInput.addEventListener("input", () => {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(() => {
          currentSearch = heroSearchInput.value.trim();
          applyFilters();
        }, 300);
      });

      // Enter hoặc click nút search → tìm ngay
      heroSearchBtn.addEventListener("click", () => {
        clearTimeout(debounceTimer);
        currentSearch = heroSearchInput.value.trim();
        applyFilters();
      });
      heroSearchInput.addEventListener("keydown", (e) => {
        if (e.key === "Enter") {
          clearTimeout(debounceTimer);
          currentSearch = heroSearchInput.value.trim();
          applyFilters();
        }
      });

      priceRange.addEventListener("input", () => {
        currentMaxPrice = parseInt(priceRange.value);
        priceDisplay.textContent =
          new Intl.NumberFormat("vi-VN").format(currentMaxPrice) + "đ";
        applyFilters();
      });
      sortSelect.addEventListener("change", () => {
        currentSort = sortSelect.value;
        applyFilters();
      });

      resetFiltersBtn.addEventListener("click", () => {
        currentSearch = "";
        currentCategories = [];
        currentMaxPrice = 2000000;
        currentBrand = "";
        currentSort = "default";
        heroSearchInput.value = "";
        priceRange.value = 2000000;
        priceDisplay.textContent = "2.000.000đ";
        sortSelect.value = "default";
        document
          .querySelectorAll(".category-filter")
          .forEach((cb) => (cb.checked = false));
        document.querySelectorAll("[name='brand']")[0].checked = true;
        applyFilters();
      });

      function showToast(message) {
        const toast = document.createElement("div");
        toast.className =
          "fixed bottom-5 right-5 z-[60] rounded-full bg-on-surface text-background px-lg py-3 shadow-lg text-label-md";
        toast.textContent = message;
        document.body.appendChild(toast);

        setTimeout(() => {
          toast.remove();
        }, 2200);
      }

      function updateCartBadge() {
        const badge = document.getElementById("cartBadge");
        if (!badge) return;

        const count = getCartItemCount();
        if (count > 0) {
          badge.textContent = count;
          badge.classList.remove("hidden");
        } else {
          badge.classList.add("hidden");
        }
      }

      // Add to cart click handler (Event delegation)
      productsGrid.addEventListener("click", async (e) => {
        const btn = e.target.closest("[data-add-id]");
        if (btn) {
          const productId = btn.dataset.addId;
          const product = allProducts.find((p) => p._id === productId);
          if (product) {
            const result = await addToCart(product, 1);
            if (result) {
              updateCartBadge();
              showToast(`Đã thêm "${product.name}" vào giỏ hàng`);
            }
          }
        }
      });

      // Mobile nav toggle
      const mobileMenuBtn = document.getElementById("mobileMenuBtn");
      const mobileMenuIcon = document.getElementById("mobileMenuIcon");
      const mobileNav = document.getElementById("mobileNav");
      mobileMenuBtn.addEventListener("click", () => {
        const isOpen = mobileNav.classList.toggle("grid-rows-[1fr]");
        mobileNav.classList.toggle("grid-rows-[0fr]", !isOpen);
        mobileMenuIcon.textContent = isOpen ? "close" : "menu";
        mobileMenuBtn.setAttribute("aria-expanded", String(isOpen));
      });

      initNav();
      updateCartBadge();
      loadProducts();
    </script>
    <script src="/js/animations.js"></script>
  </body>
</html>
