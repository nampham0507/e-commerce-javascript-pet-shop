<!doctype html>
<html lang="vi">
  <head>
    <%- include('../partials/head-meta') %>
    <title>Đơn hàng của tôi - Xám Pet Shop</title>
    <script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            colors: {
              primary: "#845400",
              "primary-container": "#ffb347",
              "on-primary-container": "#704700",
              "on-primary": "#ffffff",
              secondary: "#625f4e",
              "secondary-container": "#e8e3cd",
              background: "#fff8f4",
              surface: "#fff8f4",
              "surface-container": "#f9ecdf",
              "surface-container-low": "#fff1e5",
              "surface-container-lowest": "#ffffff",
              "surface-container-high": "#f3e6da",
              "surface-container-highest": "#eee0d4",
              "on-surface": "#211a13",
              "on-surface-variant": "#524535",
              outline: "#847463",
              "outline-variant": "#d6c3b0",
              error: "#ba1a1a",
              "error-container": "#ffdad6",
              "on-error-container": "#93000a",
              tertiary: "#006780",
            },
            borderRadius: {
              DEFAULT: "0.25rem",
              lg: "0.5rem",
              xl: "0.75rem",
              full: "9999px",
            },
            spacing: {
              lg: "24px",
              xs: "4px",
              xl: "40px",
              "margin-mobile": "16px",
              "container-max": "1200px",
              unit: "4px",
              gutter: "24px",
              sm: "8px",
              md: "16px",
            },
            fontFamily: {
              "label-md": ["Plus Jakarta Sans"],
              "headline-lg": ["Quicksand"],
              "headline-md": ["Quicksand"],
              "body-md": ["Plus Jakarta Sans"],
              "label-sm": ["Plus Jakarta Sans"],
            },
            fontSize: {
              "label-md": [
                "14px",
                {
                  lineHeight: "20px",
                  letterSpacing: "0.01em",
                  fontWeight: "600",
                },
              ],
              "headline-lg": [
                "32px",
                { lineHeight: "40px", fontWeight: "700" },
              ],
              "headline-md": [
                "24px",
                { lineHeight: "32px", fontWeight: "600" },
              ],
              "body-md": ["16px", { lineHeight: "24px", fontWeight: "400" }],
              "label-sm": ["12px", { lineHeight: "16px", fontWeight: "700" }],
            },
          },
        },
      };
    </script>
    <style>
      .material-symbols-outlined {
        font-variation-settings:
          "FILL" 0,
          "wght" 400,
          "GRAD" 0,
          "opsz" 24;
      }
      #userMenu {
        display: none;
      }
      #userMenu.open {
        display: block;
      }
      #userAvatar {
        width: 36px;
        height: 36px;
        border-radius: 9999px;
        background: #ffb347;
        color: #704700;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      /* Chatbot inline */
      #orderChatWindow {
        display: none;
        flex-direction: column;
        height: 360px;
        border: 1px solid #d6c3b0;
        border-radius: 16px;
        overflow: hidden;
        margin-top: 12px;
        background: #fff;
      }
      #orderChatWindow.open {
        display: flex;
      }
      #orderChatMessages {
        flex: 1;
        overflow-y: auto;
        padding: 12px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        background: #fff8f4;
      }
      .ochat-msg {
        max-width: 85%;
        padding: 8px 12px;
        border-radius: 14px;
        font-size: 13px;
        line-height: 1.4;
        word-wrap: break-word;
      }
      .ochat-msg.user {
        background: #845400;
        color: #fff;
        align-self: flex-end;
        border-bottom-right-radius: 4px;
      }
      .ochat-msg.bot {
        background: #ffffff;
        color: #211a13;
        align-self: flex-start;
        border: 1px solid #d6c3b0;
        border-bottom-left-radius: 4px;
      }
      .otyping-indicator {
        display: flex;
        gap: 4px;
        padding: 10px 14px;
        background: #fff;
        border: 1px solid #d6c3b0;
        border-radius: 14px;
        border-bottom-left-radius: 4px;
        align-self: flex-start;
        width: fit-content;
      }
      .otyping-dot {
        width: 5px;
        height: 5px;
        background: #845400;
        border-radius: 50%;
        animation: otyping 1.4s infinite ease-in-out both;
      }
      .otyping-dot:nth-child(1) {
        animation-delay: -0.32s;
      }
      .otyping-dot:nth-child(2) {
        animation-delay: -0.16s;
      }
      @keyframes otyping {
        0%,
        80%,
        100% {
          transform: scale(0);
        }
        40% {
          transform: scale(1);
        }
      }

      /* Return policy modal */
      #returnPolicyOverlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.4);
        z-index: 200;
        align-items: center;
        justify-content: center;
        padding: 16px;
      }
      #returnPolicyOverlay.open {
        display: flex;
      }
      #returnPolicyModal {
        background: #fff;
        border-radius: 20px;
        max-width: 560px;
        width: 100%;
        max-height: 80vh;
        overflow-y: auto;
        padding: 28px;
        box-shadow: 0 16px 40px rgba(132, 84, 0, 0.15);
        animation: modalIn 0.25s ease-out;
      }
      @keyframes modalIn {
        from {
          transform: scale(0.92);
          opacity: 0;
        }
        to {
          transform: scale(1);
          opacity: 1;
        }
      }
    </style>
  </head>
  <body class="bg-background text-on-surface">
    <%- include('../partials/navbar') %>

    <main
      class="mt-24 mb-xl max-w-container-max mx-auto px-margin-mobile md:px-lg min-h-screen"
    >
      <div class="relative overflow-hidden rounded-[24px] mb-xl px-md py-lg">
