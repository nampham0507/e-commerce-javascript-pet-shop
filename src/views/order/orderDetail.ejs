    <%- include('../partials/footer') %>

    <script type="module">
      import { isAuthenticated, getUserInfo, logoutUser } from "/js/auth.js";

      const guestNav = document.getElementById("guestNav");
      const userNav = document.getElementById("userNav");
      const mobileGuestNav = document.getElementById("mobileGuestNav");
      const userAvatar = document.getElementById("userAvatar");
      const userName = document.getElementById("userName");
      const menuUserName = document.getElementById("menuUserName");
      const menuUserEmail = document.getElementById("menuUserEmail");
      const adminLink = document.getElementById("adminLink");
      const menuAdminLink = document.getElementById("menuAdminLink");
      const userMenu = document.getElementById("userMenu");
      const chevronIcon = document.getElementById("chevronIcon");
      const logoutBtn = document.getElementById("logoutBtn");
      const userAvatarBtn = document.getElementById("userAvatarBtn");
      const cancelSection = document.getElementById("cancelSection");
      const cancelReason = document.getElementById("cancelReason");
      const cancelOrderBtn = document.getElementById("cancelOrderBtn");
      const cancelMessage = document.getElementById("cancelMessage");

      const statusMap = {
        pending: "Chờ xử lý",
        confirmed: "Đã xác nhận",
        shipped: "Đang giao",
        delivered: "Đã giao",
        cancelled: "Đã hủy",
      };

      function formatCurrency(value) {
        return new Intl.NumberFormat("vi-VN", {
          style: "currency",
          currency: "VND",
        }).format(Number(value || 0));
      }

      function renderOrderList(orders) {
        const tbody = document.getElementById("allOrdersBody");
        if (!orders.length) {
          tbody.innerHTML =
            '<tr><td colspan="5" class="px-sm py-md text-center text-on-surface-variant">Chưa có đơn hàng nào</td></tr>';
          return;
        }

        tbody.innerHTML = orders
          .map(
            (order) => `
          <tr class="hover:bg-surface-container-low/50 transition-colors">
            <td class="py-md px-sm font-bold">#${order.orderNumber}</td>
            <td class="py-md px-sm">${new Date(order.createdAt).toLocaleDateString("vi-VN")}</td>
            <td class="py-md px-sm font-bold text-primary">${formatCurrency(order.totalPrice)}</td>
            <td class="py-md px-sm"><span class="px-3 py-1 rounded-full text-label-sm font-bold ${order.status === "cancelled" ? "bg-error-container text-on-error-container" : order.status === "delivered" ? "bg-green-100 text-green-700" : "bg-primary-container text-on-primary-container"}">${statusMap[order.status] || order.status}</span></td>
            <td class="py-md px-sm"><a href="/order/detail?id=${order._id}" class="text-primary font-bold hover:underline">Chi tiết</a></td>
          </tr>
        `
          )
          .join("");
      }

      function renderProducts(order) {
        const container = document.getElementById("productsContainer");
        const items = order.products || [];

        if (!items.length) {
          container.innerHTML =
            '<p class="text-on-surface-variant">Không có sản phẩm trong đơn hàng.</p>';
          return;
        }

        container.innerHTML = items
          .map((item) => {
            const subtotal = (item.price || 0) * (item.quantity || 1);
            return `
            <div class="flex gap-md p-sm hover:bg-surface-container-low/50 rounded-xl border-b border-outline-variant/30 last:border-b-0">
              <div class="img-zoom w-24 h-24 bg-white rounded-xl overflow-hidden border border-outline-variant/30 p-2 flex-shrink-0">
                <img class="w-full h-full object-contain" src="${item.product?.image || "https://via.placeholder.com/96"}" alt="${item.product?.name || "Sản phẩm"}" />
              </div>
              <div class="flex-grow flex flex-col justify-between">
                <div>
                  <h3 class="font-bold text-body-lg text-on-surface">${item.product?.name || "Sản phẩm"}</h3>
                  <p class="text-label-sm text-on-surface-variant">Danh mục: ${item.product?.category || "—"}</p>
                </div>
                <div class="flex justify-between items-end mt-2">
                  <span class="text-on-surface-variant">Số lượng: x${item.quantity}</span>
                  <span class="text-primary font-bold text-body-lg">${formatCurrency(subtotal)}</span>
                </div>
              </div>
            </div>`;
          })
          .join("");
      }

      function renderOrder(order, orders) {
        document.getElementById("breadcrumbOrder").textContent =
          `#${order.orderNumber}`;
        document.getElementById("orderHeading").textContent =
          `Mã đơn hàng: #${order.orderNumber}`;
        document.getElementById("orderDate").textContent =
          `Ngày đặt: ${new Date(order.createdAt).toLocaleString("vi-VN")}`;
        document.getElementById("orderStatusBadge").textContent =
          statusMap[order.status] || order.status;

        const recipient = order.shippingAddress || {};
        document.getElementById("recipientName").textContent =
          recipient.fullName || "—";
        document.getElementById("recipientPhone").textContent =
          recipient.phone || "—";
        document.getElementById("recipientAddress").textContent =
          [recipient.address, recipient.city].filter(Boolean).join(", ") || "—";

        renderProducts(order);

        const subtotal = (order.products || []).reduce(
          (sum, item) => sum + (item.price || 0) * (item.quantity || 1),
          0
        );
        document.getElementById("subtotalLabel").textContent =
          `Tạm tính (${order.products?.length || 0} sản phẩm)`;
        document.getElementById("subtotalValue").textContent =
          formatCurrency(subtotal);
        document.getElementById("shippingValue").textContent =
          formatCurrency(30000);
        document.getElementById("totalValue").textContent = formatCurrency(
          order.totalPrice
        );

        if (["pending", "confirmed"].includes(order.status)) {
          cancelSection.classList.remove("hidden");
        } else {
          cancelSection.classList.add("hidden");
        }

        if (order.status === "cancelled") {
          cancelMessage.textContent = `Đơn hàng đã được hủy${order.cancelReason ? ` với lý do: ${order.cancelReason}` : ""}.`;
          cancelMessage.className = "mt-3 text-sm text-on-surface-variant";
        } else {
          cancelMessage.textContent = "";
        }
      }

      async function loadOrders() {
        const token = localStorage.getItem("token");
        if (!token) {
          window.location.href = "/auth/login";
          return;
        }

        const response = await fetch("/api/orders", {
          headers: { Authorization: `Bearer ${token}` },
        });

        const data = await response.json();
        if (!response.ok || !data.success) {
          throw new Error(data.message || "Không thể tải đơn hàng của bạn.");
        }

        const orders = data.orders || [];
        const selectedOrderId = new URLSearchParams(window.location.search).get(
          "id"
        );

        if (orders.length === 0) {
          document.getElementById("emptyState").classList.remove("hidden");
          return;
        }

        if (selectedOrderId) {
          const order = orders.find((item) => item._id === selectedOrderId);
          if (order) {
            document
              .getElementById("orderHeaderDetail")
              .classList.remove("hidden");
            document.getElementById("mainContent").classList.remove("hidden");
            renderOrder(order, orders);
          } else {
            window.location.href = "/order/detail";
          }
        } else {
          document.getElementById("orderListView").classList.remove("hidden");
          renderOrderList(orders);
        }

        // Re-trigger scroll reveal and other animations on newly revealed elements
        if (window.XamAnimations) {
          window.XamAnimations.init();
        }
      }

      async function cancelOrder(e) {
        if (e) e.preventDefault();
        const token = localStorage.getItem("token");
        if (!token) {
          window.location.href = "/auth/login";
          return;
        }

        const reason = cancelReason.value;
        if (!reason) {
          alert("Vui lòng chọn lý do hủy đơn.");
          return;
        }

        try {
          const selectedOrderId = new URLSearchParams(
            window.location.search
          ).get("id");
          const ordersRes = await fetch("/api/orders", {
            headers: { Authorization: `Bearer ${token}` },
          });
          const orders = await ordersRes.json();
          const currentOrder =
            orders.orders?.find((item) => item._id === selectedOrderId) ||
            orders.orders?.[0];

          if (!currentOrder) {
            alert("Không tìm thấy đơn hàng để hủy.");
            return;
          }

          const response = await fetch(
            `/api/orders/${currentOrder._id}/cancel`,
            {
              method: "PATCH",
              headers: {
                Authorization: `Bearer ${token}`,
                "Content-Type": "application/json",
              },
              body: JSON.stringify({ cancelReason: reason }),
            }
          );

          if (!response.ok) {
            const text = await response.text();
            console.error("Server Error Response:", text);
            try {
              const data = JSON.parse(text);
              alert(data.message || "Không thể hủy đơn hàng.");
            } catch (e) {
              alert("Lỗi máy chủ (404/500). Vui lòng thử lại.");
            }
            return;
          }

          const data = await response.json();
          if (!data.success) {
            alert(data.message || "Không thể hủy đơn hàng.");
            return;
          }

          alert("Hủy đơn hàng thành công.");
          window.location.reload();
        } catch (error) {
          console.error("Cancel Order Error:", error);
          alert("Có lỗi xảy ra: " + error.message);
        }
      }

      function initNav() {
        if (isAuthenticated()) {
          const user = getUserInfo();
          if (!user) return;
          guestNav.style.display = "none";
          userNav.style.display = "flex";
          mobileGuestNav.classList.add("hidden");
          mobileGuestNav.classList.remove("flex");
          userAvatar.textContent = (user.fullName || user.email || "U")
            .charAt(0)
            .toUpperCase();
          userName.textContent = user.fullName || user.email;
          menuUserName.textContent = user.fullName || user.email;
          menuUserEmail.textContent = user.email || "";
          if (user.role === "admin") {
            adminLink.style.display = "flex";
            menuAdminLink.style.display = "flex";
          }
        } else {
          guestNav.style.display = "";
          userNav.style.display = "none";
          mobileGuestNav.classList.remove("hidden");
          mobileGuestNav.classList.add("flex");
        }
      }

      userAvatarBtn.addEventListener("click", (e) => {
        e.stopPropagation();
        const isOpen = userMenu.classList.toggle("open");
        chevronIcon.textContent = isOpen ? "expand_less" : "expand_more";
      });

      document.addEventListener("click", () => {
        userMenu.classList.remove("open");
        chevronIcon.textContent = "expand_more";
      });

      logoutBtn.addEventListener("click", async () => {
        await logoutUser();
        window.location.href = "/auth/login";
      });

      cancelOrderBtn.addEventListener("click", cancelOrder);

      // ===== Chatbot Logic =====
      const orderChatWindow = document.getElementById("orderChatWindow");
      const toggleOrderChatBtn = document.getElementById("toggleOrderChatBtn");
      const closeOrderChatBtn = document.getElementById("closeOrderChatBtn");
      const orderChatInput = document.getElementById("orderChatInput");
      const sendOrderChatBtn = document.getElementById("sendOrderChatBtn");
      const orderChatMessages = document.getElementById("orderChatMessages");

      let orderChatHistory = [];
      let orderIsTyping = false;

      toggleOrderChatBtn.addEventListener("click", () => {
        const isOpen = orderChatWindow.classList.toggle("open");
        toggleOrderChatBtn.innerHTML = isOpen
          ? '<span class="material-symbols-outlined">expand_less</span> Ẩn chat'
          : '<span class="material-symbols-outlined">headset_mic</span> Chát với CSKH';
        if (isOpen) orderChatInput.focus();
      });

      closeOrderChatBtn.addEventListener("click", () => {
        orderChatWindow.classList.remove("open");
        toggleOrderChatBtn.innerHTML =
          '<span class="material-symbols-outlined">headset_mic</span> Chát với CSKH';
      });

      function addOChatMsg(content, sender) {
        const div = document.createElement("div");
        div.className = `ochat-msg ${sender}`;
        div.textContent = content;
        orderChatMessages.appendChild(div);
        orderChatMessages.scrollTop = orderChatMessages.scrollHeight;
      }

      function showOTyping() {
        const div = document.createElement("div");
        div.className = "otyping-indicator";
        div.id = "oTypingIndicator";
        div.innerHTML =
          '<div class="otyping-dot"></div><div class="otyping-dot"></div><div class="otyping-dot"></div>';
        orderChatMessages.appendChild(div);
        orderChatMessages.scrollTop = orderChatMessages.scrollHeight;
      }

      function hideOTyping() {
        const el = document.getElementById("oTypingIndicator");
        if (el) el.remove();
      }

      async function handleOrderChat() {
        const message = orderChatInput.value.trim();
        if (!message || orderIsTyping) return;

        orderChatInput.value = "";
        addOChatMsg(message, "user");
        orderIsTyping = true;
        sendOrderChatBtn.disabled = true;
        showOTyping();

        try {
          const resp = await fetch("/api/chat", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ message, history: orderChatHistory }),
          });
          const data = await resp.json();
          hideOTyping();

          if (data.success) {
            addOChatMsg(data.message, "bot");
            orderChatHistory.push({ role: "user", content: message });
            orderChatHistory.push({ role: "assistant", content: data.message });
            if (orderChatHistory.length > 10)
              orderChatHistory = orderChatHistory.slice(-10);
          } else {
            addOChatMsg(
              data.message ||
                "Rất tiếc, mình đang gặp lỗi kỹ thuật. Bạn thử lại sau nhé!",
              "bot"
            );
          }
        } catch (err) {
          console.error("Chat Error:", err);
          hideOTyping();
          addOChatMsg(
            "Không thể kết nối đến máy chủ. Vui lòng kiểm tra mạng.",
            "bot"
          );
        } finally {
          orderIsTyping = false;
          sendOrderChatBtn.disabled = false;
          orderChatInput.focus();
        }
      }

      sendOrderChatBtn.addEventListener("click", handleOrderChat);
      orderChatInput.addEventListener("keypress", (e) => {
        if (e.key === "Enter") handleOrderChat();
      });

      // ===== Return Policy Modal =====
      const returnPolicyOverlay = document.getElementById(
        "returnPolicyOverlay"
      );
      const openReturnPolicyBtn = document.getElementById(
        "openReturnPolicyBtn"
      );
      const closeReturnPolicyBtn = document.getElementById(
        "closeReturnPolicyBtn"
      );
      const closeReturnPolicyBtn2 = document.getElementById(
        "closeReturnPolicyBtn2"
      );

      openReturnPolicyBtn.addEventListener("click", () => {
        returnPolicyOverlay.classList.add("open");
      });

      function closeReturnPolicy() {
        returnPolicyOverlay.classList.remove("open");
      }

      closeReturnPolicyBtn.addEventListener("click", closeReturnPolicy);
      closeReturnPolicyBtn2.addEventListener("click", closeReturnPolicy);
      returnPolicyOverlay.addEventListener("click", (e) => {
        if (e.target === returnPolicyOverlay) closeReturnPolicy();
      });

      // Mobile nav toggle
      const mobileMenuBtn = document.getElementById("mobileMenuBtn");
      const mobileMenuIcon = document.getElementById("mobileMenuIcon");
      const mobileNav = document.getElementById("mobileNav");
      mobileMenuBtn.addEventListener("click", () => {
        const isOpen = mobileNav.classList.toggle("grid-rows-[1fr]");
        mobileNav.classList.toggle("grid-rows-[0fr]", !isOpen);
        mobileMenuIcon.textContent = isOpen ? "close" : "menu";
        mobileMenuBtn.setAttribute("aria-expanded", String(isOpen));
      });

      initNav();
      loadOrders().catch((error) => {
        document.getElementById("mainContent").classList.add("hidden");
        document.getElementById("emptyState").classList.remove("hidden");
        document.getElementById("emptyState").innerHTML =
          `<h2 class="font-headline-md text-headline-md mb-sm">Không thể tải đơn hàng</h2><p class="text-on-surface-variant mb-lg">${error.message}</p>`;
      });
    </script>
    <script src="/js/animations.js"></script>
  </body>
</html>
