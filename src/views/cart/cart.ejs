    <style>
      .material-symbols-outlined {
        font-variation-settings:
          "FILL" 0,
          "wght" 400,
          "GRAD" 0,
          "opsz" 24;
      }
      /* User dropdown */
      #userMenu {
        display: none;
      }
      #userMenu.open {
        display: block;
      }
      .soft-shadow {
        box-shadow: 0 10px 30px -10px rgba(132, 84, 0, 0.08);
      }
      .squishy-active:active {
        transform: scale(0.95);
        transition: transform 0.1s ease;
      }
      ::-webkit-scrollbar {
        width: 8px;
      }
      ::-webkit-scrollbar-track {
        background: #fff8f4;
      }
      ::-webkit-scrollbar-thumb {
        background: #d6c3b0;
        border-radius: 10px;
      }
    </style>
  </head>
  <body
    class="bg-background text-on-background font-body-md selection:bg-primary-fixed selection:text-on-primary-fixed"
  >
    <%- include('../partials/navbar', { activePage: 'cart' }) %>

    <main class="max-w-container-max mx-auto px-margin-mobile md:px-lg pt-32 pb-xl">
      <div class="relative overflow-hidden rounded-[24px] mb-xl px-md py-lg">
        <div class="gradient-mesh"></div>
        <div
          class="relative z-10 flex items-center gap-xs text-on-surface-variant mb-md font-label-sm text-label-sm"
        >
          <a class="hover:text-primary" href="/">Trang chủ</a>
          <span class="material-symbols-outlined text-[14px]">chevron_right</span>
          <span class="text-primary">Giỏ hàng</span>
        </div>
        <h1 class="relative z-10 font-headline-xl text-headline-xl text-on-background reveal section-heading">
          Giỏ hàng của bạn
        </h1>
      </div>
      <div class="flex flex-col lg:grid lg:grid-cols-12 gap-xl">
        <div class="lg:col-span-8 space-y-md">
          <div
            class="hidden md:grid grid-cols-12 gap-md px-md py-sm border-b border-outline-variant text-on-surface-variant font-label-md"
          >
            <div class="col-span-6">Chi tiết sản phẩm</div>
            <div class="col-span-2 text-center">Giá</div>
            <div class="col-span-2 text-center">Số lượng</div>
            <div class="col-span-2 text-right">Thành tiền</div>
          </div>
          <div id="cartItemsContainer" class="space-y-md"></div>
          <div class="pt-lg flex items-center">
            <a
              class="flex items-center gap-sm text-primary font-bold hover:gap-md transition-all group"
              href="/product"
            >
              <span class="material-symbols-outlined">arrow_back</span>
              Tiếp tục mua sắm
            </a>
          </div>
        </div>

        <aside class="lg:col-span-4">
          <div
            class="bg-surface-container-low p-lg rounded-[32px] soft-shadow sticky top-32 reveal-right delay-2"
          >
            <h2 class="font-headline-md text-headline-md text-on-surface mb-lg">
              Tóm tắt đơn hàng
            </h2>
            <div class="space-y-md mb-lg">
              <div class="flex justify-between items-center">
                <span class="text-on-surface-variant">Subtotal</span>
                <span id="subtotalValue" class="font-bold text-on-surface"
                  >0₫</span
                >
              </div>
              <div class="flex justify-between items-center">
                <span class="text-on-surface-variant">Phí vận chuyển</span>
                <span id="shippingValue" class="font-bold text-on-surface"
                  >30.000₫</span
                >
              </div>
              <div class="pt-md border-t border-outline-variant">
                <div class="flex justify-between items-center mb-xs">
                  <span class="font-bold text-body-lg text-on-surface"
                    >Tổng</span
                  >
                  <span
                    id="totalValue"
                    class="font-headline-md text-headline-md text-primary"
                    >0₫</span
                  >
                </div>
                <p
                  id="itemCountLabel"
                  class="text-label-sm text-outline text-right italic"
                >
                  0 sản phẩm
                </p>
              </div>
            </div>
            <a
              id="checkoutBtn"
              href="/order/checkout"
              class="btn-shine block w-full bg-primary-container text-on-primary-container font-headline-md py-lg rounded-full flex items-center justify-center gap-md hover:scale-[1.02] active:scale-95 transition-all shadow-md group anim-pulse-glow btn-ripple"
            >
              Tiến hành thanh toán
              <span
                class="material-symbols-outlined transition-transform group-hover:translate-x-1"
                >shopping_cart_checkout</span
              >
            </a>
            <div
              class="mt-xl grid grid-cols-3 gap-sm opacity-60 grayscale hover:grayscale-0 transition-all duration-500"
            >
              <div class="flex flex-col items-center text-center gap-xs">
                <span class="material-symbols-outlined text-primary text-[24px]"
                  >verified_user</span
                >
                <span class="text-[10px] font-bold">An toàn</span>
              </div>
              <div class="flex flex-col items-center text-center gap-xs">
                <span class="material-symbols-outlined text-primary text-[24px]"
                  >local_shipping</span
                >
                <span class="text-[10px] font-bold">Nhanh chóng</span>
              </div>
              <div class="flex flex-col items-center text-center gap-xs">
                <span class="material-symbols-outlined text-primary text-[24px]"
                  >published_with_changes</span
                >
                <span class="text-[10px] font-bold">Hoàn 30 ngày</span>
              </div>
            </div>
          </div>
        </aside>
      </div>
    </main>

    <%- include('../partials/footer') %>

    <script type="module">
      import { isAuthenticated, getUserInfo, logoutUser } from "/js/auth.js";
      import {
        getCart,
        removeFromCart,
        updateCartQuantity,
        getCartTotal,
        getCartItemCount,
        syncCartFromBackend,
      } from "/js/cart.js?v=1780539375679";

      const guestNav = document.getElementById("guestNav");
      const userNav = document.getElementById("userNav");
      const userAvatar = document.getElementById("userAvatar");
      const userName = document.getElementById("userName");
      const menuUserName = document.getElementById("menuUserName");
      const menuUserEmail = document.getElementById("menuUserEmail");
      const adminLink = document.getElementById("adminLink");
      const menuAdminLink = document.getElementById("menuAdminLink");
      const userMenu = document.getElementById("userMenu");
      const chevronIcon = document.getElementById("chevronIcon");
      const logoutBtn = document.getElementById("logoutBtn");
      const userAvatarBtn = document.getElementById("userAvatarBtn");
      const cartItemsContainer = document.getElementById("cartItemsContainer");
      const subtotalValue = document.getElementById("subtotalValue");
      const shippingValue = document.getElementById("shippingValue");
      const totalValue = document.getElementById("totalValue");
      const itemCountLabel = document.getElementById("itemCountLabel");
      const checkoutBtn = document.getElementById("checkoutBtn");
      const mobileGuestNav = document.getElementById("mobileGuestNav");

      function initNav() {
        if (isAuthenticated()) {
          const user = getUserInfo();
          if (!user) return;
          guestNav.style.display = "none";
          userNav.style.display = "flex";
          const initial = (user.fullName || user.email || "U")
            .charAt(0)
            .toUpperCase();
          userAvatar.textContent = initial;
          const displayName = user.fullName || user.email;
          userName.textContent = displayName;
          menuUserName.textContent = displayName;
          menuUserEmail.textContent = user.email || "";
          if (user.role === "admin") {
            adminLink.style.display = "flex";
            menuAdminLink.style.display = "flex";
          }
          mobileGuestNav.classList.add("hidden");
          mobileGuestNav.classList.remove("flex");
        } else {
          guestNav.style.display = "";
          userNav.style.display = "none";
          mobileGuestNav.classList.remove("hidden");
          mobileGuestNav.classList.add("flex");
        }
      }

      function formatCurrency(value) {
        return new Intl.NumberFormat("vi-VN", {
          style: "currency",
          currency: "VND",
          maximumFractionDigits: 0,
        }).format(value);
      }

      function updateCartBadge() {
        const badge = document.getElementById("cartBadge");
        if (!badge) return;
        const count = getCartItemCount();
        if (count > 0) {
          badge.textContent = count;
          badge.classList.remove("hidden");
        } else {
          badge.classList.add("hidden");
        }
      }

      function renderCartItems() {
        const cart = getCart();
        if (!cart.length) {
          cartItemsContainer.innerHTML = `
            <div class="bg-white p-lg rounded-[24px] soft-shadow border border-outline-variant/30 text-center">
              <p class="text-on-surface-variant mb-md">Giỏ hàng đang trống.</p>
              <a href="/product" class="inline-flex items-center justify-center bg-primary-container text-on-primary-container px-lg py-sm rounded-full font-label-md">Khám phá sản phẩm</a>
            </div>`;
          subtotalValue.textContent = formatCurrency(0);
          if (shippingValue) shippingValue.textContent = formatCurrency(0);
          totalValue.textContent = formatCurrency(0);
          itemCountLabel.textContent = "0 sản phẩm";
          checkoutBtn.classList.add("pointer-events-none", "opacity-50");
          return;
        }

        checkoutBtn.classList.remove("pointer-events-none", "opacity-50");
        cartItemsContainer.innerHTML = cart
          .map(
            (item) => `
            <div class="card-hover bg-white p-md rounded-[24px] soft-shadow border border-outline-variant/30 flex flex-col md:grid md:grid-cols-12 md:items-center gap-md group">
              <div class="col-span-6 flex items-center gap-md">
                <div class="img-zoom w-24 h-24 bg-surface-container rounded-xl overflow-hidden flex-shrink-0">
                  <img alt="${item.name}" class="w-full h-full object-cover" src="${item.image || "https://via.placeholder.com/96?text=No+Image"}" />
                </div>
                <div class="flex flex-col gap-xs">
                  <h3 class="font-headline-md text-[18px] text-on-surface"><a href="/product/detail?id=${item._id}" class="hover:text-primary">${item.name}</a></h3>
                  <button data-remove-id="${item._id}" class="text-error font-label-sm flex items-center gap-1 mt-2 hover:underline">
                    <span class="material-symbols-outlined text-[16px]">delete</span>
                    Xóa
                  </button>
                </div>
              </div>
              <div class="col-span-2 text-center font-semibold text-on-surface">${formatCurrency(item.price)}</div>
              <div class="col-span-2 flex justify-center">
                <div class="flex items-center bg-surface-container-low rounded-full px-2 py-1">
                  <button data-decrease-id="${item._id}" class="w-8 h-8 flex items-center justify-center hover:bg-surface-container-high rounded-full transition-colors squishy-active">
                    <span class="material-symbols-outlined text-sm">remove</span>
                  </button>
                  <span class="w-8 text-center font-bold">${item.quantity}</span>
                  <button data-increase-id="${item._id}" class="w-8 h-8 flex items-center justify-center hover:bg-surface-container-high rounded-full transition-colors squishy-active">
                    <span class="material-symbols-outlined text-sm">add</span>
                  </button>
                </div>
              </div>
              <div class="col-span-2 text-right font-bold text-primary text-body-lg">${formatCurrency(item.price * item.quantity)}</div>
            </div>
          `
          )
          .join("");

        const subtotal = getCartTotal();
        const shippingFee = cart.length > 0 ? 30000 : 0;
        subtotalValue.textContent = formatCurrency(subtotal);
        if (shippingValue)
          shippingValue.textContent = formatCurrency(shippingFee);
        totalValue.textContent = formatCurrency(subtotal + shippingFee);
        itemCountLabel.textContent = `${cart.reduce((sum, item) => sum + item.quantity, 0)} sản phẩm`;

        cartItemsContainer
          .querySelectorAll("[data-remove-id]")
          .forEach((button) => {
            button.addEventListener("click", async () => {
              await removeFromCart(button.dataset.removeId);
              renderCartItems();
              updateCartBadge();
            });
          });

        cartItemsContainer
          .querySelectorAll("[data-decrease-id]")
          .forEach((button) => {
            button.addEventListener("click", async () => {
              const currentItem = getCart().find(
                (item) => item._id === button.dataset.decreaseId
              );
              const nextQty = currentItem
                ? Math.max(1, currentItem.quantity - 1)
                : 1;
              await updateCartQuantity(button.dataset.decreaseId, nextQty);
              renderCartItems();
              updateCartBadge();
            });
          });

        cartItemsContainer
          .querySelectorAll("[data-increase-id]")
          .forEach((button) => {
            button.addEventListener("click", async () => {
              const currentItem = getCart().find(
                (item) => item._id === button.dataset.increaseId
              );
              const nextQty = currentItem ? currentItem.quantity + 1 : 1;
              await updateCartQuantity(button.dataset.increaseId, nextQty);
              renderCartItems();
              updateCartBadge();
            });
          });
      }

      userAvatarBtn.addEventListener("click", (e) => {
        e.stopPropagation();
        const isOpen = userMenu.classList.toggle("open");
        chevronIcon.textContent = isOpen ? "expand_less" : "expand_more";
      });

      document.addEventListener("click", () => {
        userMenu.classList.remove("open");
        chevronIcon.textContent = "expand_more";
      });

      logoutBtn.addEventListener("click", async () => {
        await logoutUser();
        window.location.href = "/auth/login";
      });

      window.addEventListener("scroll", () => {
        const header = document.querySelector("header");
        if (!header) return;
        if (window.scrollY > 10) {
          header.classList.add("shadow-md");
        } else {
          header.classList.remove("shadow-md");
        }
      });

      async function initCartPage() {
        initNav();
        if (isAuthenticated()) {
          await syncCartFromBackend();
        }
        updateCartBadge();
        renderCartItems();
      }

      initCartPage();

      // Mobile nav toggle
      const mobileMenuBtn = document.getElementById("mobileMenuBtn");
      const mobileMenuIcon = document.getElementById("mobileMenuIcon");
      const mobileNav = document.getElementById("mobileNav");
      mobileMenuBtn.addEventListener("click", () => {
        const isOpen = mobileNav.classList.toggle("grid-rows-[1fr]");
        mobileNav.classList.toggle("grid-rows-[0fr]", !isOpen);
        mobileMenuIcon.textContent = isOpen ? "close" : "menu";
        mobileMenuBtn.setAttribute("aria-expanded", String(isOpen));
      });
    </script>
    <script src="/js/animations.js"></script>
  </body>
</html>
